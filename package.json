{
  "name": "gladpros-nextjs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next dev",
    "predev": "node scripts/dev/build-ui-if-needed.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "prebuild": "npm run build -w @gladpros/ui",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit",
    "test": "jest",
    "test:integration": "jest -c config/jest.integration.config.js --runInBand --passWithNoTests",
    "test:unit": "jest --selectProjects unit",
    "test:all": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config playwright.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:integration:json": "jest -c config/jest.integration.config.js --runInBand --passWithNoTests --json --outputFile=tests/.reports/jest-integration.json",
    "test:changed:pr": "node scripts/jest-changed-pr.js",
    "test:database": "jest -c config/jest.database.config.js --runInBand --passWithNoTests",
    "integration:guard": "node scripts/ci/check-integration-baseline.mjs",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "config:validate": "node scripts/maintenance/config-validate.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx scripts/seed-smoke-user.js",
    "db:reset": "prisma migrate reset",
    "kms:init": "node scripts/kms-cli.js init",
    "kms:rotate": "node scripts/kms-cli.js rotate",
    "kms:status": "node scripts/kms-cli.js status",
    "kms:maintenance": "node scripts/kms-cli.js maintenance",
    "kms:validate": "node scripts/kms-cli.js validate",
    "clean": "rimraf .next dist build coverage playwright-report test-results",
    "clean:install": "rimraf node_modules package-lock.json && npm install",
    "check": "npm run lint && npm run type-check && npm test",
    "check:all": "npm run check && npm run build",
    "check:smoke": "npm run build",
    "verify": "npm ci && npm run db:generate && npm run check:all",
    "verify:smoke": "npm ci && npm run db:generate && npm run check:smoke",
    "verify:ci": "npm run verify:smoke",
    "quality:lint": "npm run lint",
    "quality:types": "tsc -p tsconfig.typecheck.json",
    "quality:test": "npm test",
    "secret:scan": "node scripts/maintenance/secret-scan.js",
    "health:check": "node scripts/check-module-health.mjs",
    "health:check:module": "node scripts/check-module-health.mjs --module",
    "semgrep": "semgrep --config=.semgrep/gladpros --metrics=off --error",
    "semgrep:staged": "semgrep --config=.semgrep/gladpros --metrics=off --error --baseline-commit=HEAD",
    "known-bugs:validate": "node scripts/validate-known-bugs.mjs",
    "quality:gate": "npm run known-bugs:validate && npm run semgrep && npm run health:check",
    "db:fix-sessions": "node scripts/fix-missing-tables.js",
    "test:smoke": "cross-env BASE_URL=http://localhost:3001 dotenv -e .env.test -- node scripts/smoke-auth.mjs",
    "test:db:reset": "node scripts/test-reset-db.js",
    "dev:test": "dotenv -e .env.test -- next dev -p 3001",
    "test:ci": "npm run test:db:reset && npm run test:smoke",
    "qa:clientes:rbac": "playwright test tests/e2e/clientes/clientes-rbac.spec.ts --project=chromium --config playwright.config.ts",
    "qa:clientes:functional": "playwright test tests/e2e/clientes/clientes-crud.spec.ts tests/e2e/clientes/clientes-guards.spec.ts --project=chromium --config playwright.config.ts",
    "qa:clientes:smoke": "playwright test tests/e2e/clientes/clientes-smoke.spec.ts --project=chromium --config playwright.config.ts",
    "qa:clientes": "npm run qa:clientes:rbac && npm run qa:clientes:functional && npm run qa:clientes:smoke",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "cache:clear": "node scripts/maintenance/cache-manager.js clear",
    "cache:stats": "node scripts/maintenance/cache-manager.js stats",
    "cache:health": "node scripts/maintenance/cache-manager.js health",
    "cache:warmup": "npx tsx -e \"require('./src/lib/cache/business-cache').BusinessCache.warmupCache()\"",
    "packages:build": "npm run build --workspaces",
    "packages:install": "npm install",
    "postinstall": "node -e \"process.env.DATABASE_URL=process.env.DATABASE_URL||'mysql://root:root@localhost:3306/gladpros_ci';require('child_process').execSync('prisma generate',{stdio:'inherit'});\"",
    "audit:repo": "node scripts/audit-repo.mjs",
    "audit:css": "node scripts/find-dead-css.mjs",
    "doc:update": "node scripts/update-doc-section.mjs",
    "format": "prettier --write .",
    "prepare": "husky install",
    "build:e2e": "cross-env E2E_BUILD=1 NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start:e2e": "next start -p 3007",
    "serve:e2e": "npm run build:e2e && next start -p 3007",
    "test:e2e:built": "PLAYWRIGHT_SKIP_SERVER=1 BASE_URL=http://127.0.0.1:3007 playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gladpros/ui": "*",
    "@hookform/resolvers": "^5.2.1",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.48.0",
    "bcryptjs": "^3.0.2",
    "chart.js": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.7",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.12",
    "grammy": "^1.43.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.7.0",
    "isomorphic-dompurify": "^2.28.0",
    "jose": "^6.0.12",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.525.0",
    "mysql2": "^3.16.1",
    "next": "^15.5.10",
    "nodemailer": "^8.0.4",
    "openai": "^6.35.0",
    "pdf-lib": "^1.17.1",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "prisma": "^6.14.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-day-picker": "^9.9.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.1.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.0.6",
    "concurrently": "^9.2.1",
    "critters": "^0.0.23",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.3.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-mock-extended": "^4.0.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.10.5",
    "node-fetch": "^2.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.2",
    "storybook": "^8.6.14",
    "supertest": "^7.1.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "vitest": "^4.0.6",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
