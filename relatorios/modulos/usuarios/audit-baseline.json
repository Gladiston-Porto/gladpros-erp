{
  "module": "usuarios",
  "createdAt": "2026-05-25",
  "purpose": "Inventário-baseline do módulo usuarios. Usado pelo run-audit.mjs para detectar drift estrutural e habilitar o canário do detector de anti-patterns.",
  "scope": {
    "apiRoutes": "src/app/api/usuarios/**",
