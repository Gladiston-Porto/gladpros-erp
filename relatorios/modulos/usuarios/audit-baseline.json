      "src/shared/lib/usuario-query.ts",
      "src/shared/lib/rbac.ts",
      "src/shared/lib/rbac-core.ts"
    ]
  },
  "criticalInvariants": [
    {
      "id": "P1-USUARIOS-001",
      "rule": "Toda rota de usuarios deve usar requireUser/requireServerUser + can('usuarios', action).",
      "enforcedBy": ".semgrep/gladpros/can-check-on-usuarios-route.yml"
    },
    {
      "id": "P1-USUARIOS-002",
      "rule": "Toda query de usuario deve incluir empresaId no where (multi-tenant safety, mesmo single-tenant).",
      "enforcedBy": ".semgrep/gladpros/empresaId-on-prisma-where.yml"
    },
    {
      "id": "P1-USUARIOS-003",
      "rule": "Desativação/exclusão de usuário deve incrementar tokenVersion para invalidar JWT.",
      "enforcedBy": ".semgrep/gladpros/tokenVersion-on-user-deactivation.yml"
    },
    {
      "id": "P2-USUARIOS-PERF",
      "rule": "Nenhuma query de usuários pode usar INFORMATION_SCHEMA (lento). Exceção: src/shared/lib/usuario-query.ts.",
      "enforcedBy": "scripts/check-module-health.mjs (regex INFORMATION_SCHEMA)"
    },
    {
      "id": "P2-USUARIOS-CONTRACT",
      "rule": "Resposta de erro deve seguir { error, message, success: false }.",
      "enforcedBy": "scripts/check-module-health.mjs"
    }
  ],
