# ─────────────────────────────────────────────────────────────
# GladPros ERP — Variáveis de Ambiente de PRODUÇÃO
# Copie para .env.production e preencha todos os valores
# NUNCA commitar .env.production no repositório
# ─────────────────────────────────────────────────────────────

# ── Banco de Dados ────────────────────────────────────────────
# (docker-compose monta isso automaticamente, mas mantenha aqui para referência)
DATABASE_URL="mysql://gladpros_user:SENHA_FORTE_AQUI@db:3306/gladpros?connection_limit=10&pool_timeout=20"
MYSQL_ROOT_PASSWORD="ROOT_SENHA_MUITO_FORTE"
MYSQL_USER="gladpros_user"
MYSQL_PASSWORD="SENHA_FORTE_AQUI"

# ── Segurança ─────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="gerar-com-node-crypto-randomBytes-64-hex"

# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CLIENT_DOC_ENCRYPTION_KEY_BASE64="gerar-com-node-crypto-randomBytes-32-base64"

# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="gerar-com-node-crypto-randomBytes-32-hex-64chars"

# ── Next.js ───────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_URL="https://app.gladpros.com"
NODE_ENV="production"

# ── Performance (OBRIGATÓRIO em produção) ─────────────────────
# Elimina query ao INFORMATION_SCHEMA no boot (evita latência de ~10s)
TOKEN_VERSION_COLUMN_EXISTS=1
# Elimina 1 query ao banco por request autenticada (JWT já validado pelo middleware)
RBAC_TRUST_JWT=1

# ── Redis (opcional — rate limiting distribuído) ──────────────
# Se NÃO tiver Redis na VPS, mantenha REDIS_DISABLED=true
REDIS_DISABLED=true
# Se tiver Redis:
# REDIS_DISABLED=false
# REDIS_URL="redis://localhost:6379"

# ── Email / SMTP (Hostinger) ──────────────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="noreply@gladpros.com"
SMTP_PASS="sua-senha-de-email"
SMTP_FROM="GladPros <noreply@gladpros.com>"
SMTP_SECURE="true"

# ── Sentry (monitoramento de erros) ──────────────────────────
# Obter em: https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=""
SENTRY_ORG="gladpros"
SENTRY_PROJECT="gladpros-erp"
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Uploads ───────────────────────────────────────────────────
# Diretório local no container (mapeado como volume)
UPLOAD_DIR="/app/uploads"
MAX_FILE_SIZE_MB="10"

# ── Seed (só usar na primeira instalação) ────────────────────
# Remover após o primeiro deploy
# SEED_ADMIN_EMAIL="admin@gladpros.com"
# SEED_ADMIN_PASS="TrocaPorSenhaMuitoForte@2026"
