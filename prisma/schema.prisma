// ============================================================================
// MÓDULO: RECEITAS (REVENUE) - SEMANA 1
// ============================================

model Revenue {
  id             Int            @id @default(autoincrement())
  empresaId      Int
  categoriaId    Int
  clienteId      Int?
  descricao      String         @db.VarChar(255)
  valor          Decimal        @db.Decimal(10, 2)
  dataEmissao    DateTime
  dataVencimento DateTime
  dataPagamento  DateTime?
  tipo           TipoReceita
  formaPagamento FormaPagamento
  status         StatusReceita
  observacoes    String?        @db.Text
  recorrente     Boolean        @default(false)
  recorrenciaId  Int?           @unique
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  empresa          Empresa             @relation(fields: [empresaId], references: [id])
  categoria        RevenueCategory     @relation(fields: [categoriaId], references: [id])
  cliente          Cliente?            @relation(fields: [clienteId], references: [id])
  recorrencia      RevenueRecurrence?  @relation("RevenueToRecurrence", fields: [recorrenciaId], references: [id])
  recorrencias     RevenueRecurrence[] @relation("RecurrenceOrigin")
  bankTransactions BankTransaction[]

  @@index([empresaId])
  @@index([categoriaId])
  @@index([clienteId])
  @@index([dataVencimento])
  @@index([status])
  @@map("revenues")
}

model RevenueCategory {
  id        Int      @id @default(autoincrement())
  empresaId Int
  nome      String   @db.VarChar(100)
  descricao String?  @db.Text
  cor       String?  @db.VarChar(7)
  icone     String?  @db.VarChar(50)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  empresa  Empresa   @relation(fields: [empresaId], references: [id])
  receitas Revenue[]

  @@unique([empresaId, nome])
  @@map("revenue_categories")
}

model RevenueRecurrence {
  id             Int                   @id @default(autoincrement())
  revenueId      Int                   @unique
  frequencia     FrequenciaRecorrencia
  diaVencimento  Int
  dataInicio     DateTime
  dataFim        DateTime?
  proximaGeracao DateTime
  ativo          Boolean               @default(true)
  criadoEm       DateTime              @default(now())

  receita Revenue?  @relation("RevenueToRecurrence")
  geradas Revenue[] @relation("RecurrenceOrigin")

  @@index([proximaGeracao])
  @@map("revenue_recurrences")
}

// Enums para Revenue

enum TipoReceita {
  SERVICO
  VENDA_PRODUTO
  CONSULTORIA
  MENSALIDADE
  COMISSAO
  OUTROS
}

enum FormaPagamento {
