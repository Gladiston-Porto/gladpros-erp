// ─── Domain Events ──────────────────────────────────────────────────────────
model DomainEvent {
  id             String   @id @default(uuid()) @db.VarChar(36)
  name           String   @db.VarChar(100) // e.g. proposal.approved
  aggregateType  String   @map("aggregate_type") @db.VarChar(50)
  aggregateId    String   @map("aggregate_id") @db.VarChar(50)
  correlationId  String?  @map("correlation_id") @db.VarChar(36)
  payload        String   @db.LongText // JSON
  status         String   @default("PENDING") @db.VarChar(20) // PENDING, PROCESSED, FAILED
  error          String?  @db.Text
  occurredAt     DateTime @default(now()) @map("occurred_at")
  processedAt    DateTime? @map("processed_at")

  @@index([name, status], map: "de_name_status_idx")
  @@index([aggregateType, aggregateId], map: "de_aggregate_idx")
  @@index([correlationId], map: "de_correlation_idx")
  @@index([occurredAt], map: "de_occurred_idx")
  @@map("domain_events")
}

// ─── Triagem (Triage/Inspection of materials, equipment, tools) ─────
enum TriagemTipo {
  MATERIAL
  EQUIPAMENTO
  FERRAMENTA
  INSPECAO
}

enum TriagemStatus {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum TriagemPrioridade {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Triagem {
  id              Int               @id @default(autoincrement())
  projetoId       Int               @map("projeto_id")
  tipo            TriagemTipo
  status          TriagemStatus     @default(PENDENTE)
  prioridade      TriagemPrioridade @default(MEDIA)
  itemId          Int?              @map("item_id")
  motivo          String            @db.Text
  resultado       String?           @db.Text
  observacoes     String?           @db.Text
  acoesCorretivas String?           @map("acoes_corretivas") @db.Text // JSON array
  prazoEstimado   DateTime?         @map("prazo_estimado")

  usuarioSolicitanteId Int  @map("usuario_solicitante_id")
  usuarioResponsavelId Int? @map("usuario_responsavel_id")

  aberturaEm  DateTime  @default(now()) @map("abertura_em")
  conclusaoEm DateTime? @map("conclusao_em")

  projeto     Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  solicitante Usuario  @relation("TriagemSolicitante", fields: [usuarioSolicitanteId], references: [id])
  responsavel Usuario? @relation("TriagemResponsavel", fields: [usuarioResponsavelId], references: [id])

  @@index([projetoId, status], map: "triagem_projeto_status_idx")
  @@index([tipo], map: "triagem_tipo_idx")
  @@index([prazoEstimado], map: "triagem_prazo_idx")
  @@map("triagens")
}

// === V3.3 SERVICE ORDER ATTACHMENTS ===

enum ServiceOrderAttachmentType {
  BEFORE_PHOTO    // Foto do local/equipamento antes do serviço
  AFTER_PHOTO     // Foto após conclusão do serviço
  RECEIPT         // Nota fiscal de compra em campo
  RETURN_RECEIPT  // Comprovante de devolução na loja
  INVOICE_DOC     // Documento de faturamento/contrato
  OTHER           // Outro documento
}

enum ReturnDestination {
  STORE          // Devolvido na loja com reembolso
  COMPANY_STOCK  // Devolvido ao estoque da empresa
}

model ServiceOrderAttachment {
  id             Int    @id @default(autoincrement())
  serviceOrderId Int
  materialItemId Int?   // FK opcional: NF vinculada a um material específico

  type        ServiceOrderAttachmentType
  filename    String  @db.VarChar(255)  // Nome original do arquivo
  filepath    String  @db.VarChar(500)  // Caminho relativo em uploads/
  mime        String  @db.VarChar(100)
  sizeBytes   Int?

  // Contexto adicional
  caption      String?  @db.VarChar(500)  // Legenda ou descrição
  vendorName   String?  @db.VarChar(200)  // Para NF: nome da loja (Home Depot, etc.)
  receiptTotal Decimal? @db.Decimal(12, 2) // Para NF: valor total da nota (digitado pelo usuário — inclui frete, etc.)
  taxAmount    Decimal? @db.Decimal(12, 2) // Valor calculado de imposto dos materiais vinculados (referência interna)

  uploadedBy Int
  createdAt  DateTime @default(now())

  // Relations
  ServiceOrder ServiceOrder          @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  MaterialItem ServiceOrderMaterial? @relation(fields: [materialItemId], references: [id], onDelete: SetNull)
  UploadedBy   Usuario               @relation(fields: [uploadedBy], references: [id])
  materialItems AttachmentMaterial[]

  @@index([serviceOrderId])
  @@index([materialItemId])
  @@index([type])
  @@map("service_order_attachments")
}

// Junction table: many-to-many between attachments and materials
model AttachmentMaterial {
  attachmentId      Int
  materialItemId    Int
  quantityOnReceipt Decimal? @db.Decimal(10, 2)
  unitCostOnReceipt Decimal? @db.Decimal(10, 2)
  hasTax            Boolean? // null = not specified
  taxRate           Decimal? @db.Decimal(5, 2) // e.g. 8.25

  attachment   ServiceOrderAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  materialItem ServiceOrderMaterial   @relation(fields: [materialItemId], references: [id], onDelete: Cascade)

  @@id([attachmentId, materialItemId])
  @@index([materialItemId])
  @@map("attachment_materials")
}

// ============================================================================
// MÓDULO: TAX COMPLIANCE — Owner Compensation & Estimated Tax
// ============================================================================

enum TipoTributacao {
  LLC_DEFAULT // Single-member LLC → Schedule C
  S_CORP      // S-Corp election → Form 1120-S + K-1
}

enum TipoCompensacao {
  OWNER_DRAW   // LLC: withdrawal of profit (not deductible)
  SALARY       // S-Corp: W-2 salary (deductible for company)
  DISTRIBUTION // S-Corp: K-1 distribution (not deductible)
}

enum QuarterLabel {
  Q1 // Jan–Mar, due Apr 15
  Q2 // Apr–May, due Jun 15
  Q3 // Jun–Aug, due Sep 15
  Q4 // Sep–Dec, due Jan 15 next year
}

enum EstimatedTaxStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

model OwnerCompensation {
  id            Int             @id @default(autoincrement())
  empresaId     Int
  workerId      Int
  tipo          TipoCompensacao
  valor         Decimal         @db.Decimal(14, 2)
  data          DateTime
  descricao     String?         @db.VarChar(255)
  referencia    String?         @db.VarChar(100) // check number, transaction ref
  bankAccountId Int?
  criadoPor     Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  worker      Worker       @relation(fields: [workerId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  usuario     Usuario?     @relation("OwnerCompensationCriadoPor", fields: [criadoPor], references: [id])

  @@index([empresaId, data])
  @@index([workerId])
  @@index([tipo])
  @@map("owner_compensations")
}

model EstimatedTaxPayment {
  id              Int                @id @default(autoincrement())
  empresaId       Int
  taxYear         Int
  quarter         QuarterLabel
  dueDate         DateTime
  estimatedAmount Decimal            @db.Decimal(14, 2)
  paidAmount      Decimal            @default(0) @db.Decimal(14, 2)
  paidDate        DateTime?
  status          EstimatedTaxStatus @default(PENDING)
  notas           String?            @db.Text
  criadoPor       Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  empresa Empresa  @relation(fields: [empresaId], references: [id])
  usuario Usuario? @relation("EstimatedTaxCriadoPor", fields: [criadoPor], references: [id])

  @@unique([empresaId, taxYear, quarter])
  @@index([empresaId, taxYear])
  @@index([status])
  @@map("estimated_tax_payments")
}

// ── Fase 2: Texas Sales Tax Classification ───────────────────────────────────

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  EXEMPT_ORGANIZATION
  GOVERNMENT
}

enum ServiceCategory {
  REPAIR
  REMODEL
  RESTORATION
  NEW_CONSTRUCTION
  MAINTENANCE
  INSPECTION
  CONSULTATION
  OTHER
}

enum ContractType {
  LUMP_SUM
  SEPARATED
}

enum TaxMode {
  NON_TAXABLE    // No sales tax charged to client (e.g. residential lump-sum)
  TAX_EXCLUDED   // Tax added on top of price
  TAX_INCLUDED   // Tax already embedded in final price (reverse calc)
  MANUAL_REVIEW  // Cannot auto-calculate; requires ADMIN/FINANCEIRO review
}
