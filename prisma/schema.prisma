  modelo       String?  @db.VarChar(80)
  ncm          String?  @db.VarChar(20)
  pesoUnitario Decimal? @map("peso_unitario") @db.Decimal(10, 3)
  dimensoes    String?  @db.VarChar(100)
  fotoUrl      String?  @map("foto_url") @db.VarChar(255)

  // Novos campos: UPC/Barcode
  barcodeInternal String? @unique @map("barcode_internal") @db.VarChar(60)
  atributos       Json?   @map("atributos")

  estoqueMinimo         Decimal                @default(0) @map("estoque_minimo") @db.Decimal(14, 3)
  pontoReposicao        Decimal                @default(0) @map("ponto_reposicao") @db.Decimal(14, 3)
  rastreioLote          Boolean                @default(true) @map("rastreio_lote")
  serviceOrderMaterials ServiceOrderMaterial[] // V3.1
  possuiValidade        Boolean                @default(false) @map("possui_validade")

  ultimoCusto    Decimal?  @map("ultimo_custo") @db.Decimal(14, 2)
  custoMedio     Decimal?  @map("custo_medio") @db.Decimal(14, 2)
  ultimaCompraEm DateTime? @map("ultima_compra_em")

  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime? @updatedAt @map("atualizado_em")
  criadoPor     Int?      @map("criado_por")
  atualizadoPor Int?      @map("atualizado_por")

  categoria   Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  unidade     Unidade    @relation(fields: [unidadeId], references: [id], onDelete: Restrict)
  criador     Usuario?   @relation("MaterialCriador", fields: [criadoPor], references: [id], onDelete: SetNull)
  atualizador Usuario?   @relation("MaterialAtualizador", fields: [atualizadoPor], references: [id], onDelete: SetNull)

  lotes                   MaterialLote[]
  saldos                  MaterialSaldo[]
  movimentacoes           MaterialMovimentacao[]
  movimentacoesUnificadas Movimentacao[]
  projetoMateriais        ProjetoMaterialEstoque[]
  comprasItens            CompraItem[]
  purchaseOrderItems      PurchaseOrderItem[]
  alertas                 AlertaEstoque[]
