  @@index([dataInicio])
  @@map("equipamentos_manutencao")
}

// ============================================================================
// SISTEMA DE ALERTAS E COMPRAS
// ============================================================================

model AlertaEstoque {
  id              BigInt                   @id @default(autoincrement())
  tipo            AlertaEstoque_tipo
  prioridade      AlertaEstoque_prioridade @default(MEDIA)
  materialId      Int?                     @map("material_id")
  equipamentoId   Int?                     @map("equipamento_id")
  projetoId       Int?                     @map("projeto_id")
  titulo          String                   @db.VarChar(150)
  mensagem        String                   @db.Text
  dataAlerta      DateTime                 @default(now()) @map("data_alerta")
  dataVisualizado DateTime?                @map("data_visualizado")
  visualizadoPor  Int?                     @map("visualizado_por")
  dataResolvido   DateTime?                @map("data_resolvido")
  resolvidoPor    Int?                     @map("resolvido_por")
  solucao         String?                  @db.Text
  ativo           Boolean                  @default(true)

  serviceOrderId Int?                     @map("service_order_id")

  material     Material?      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  equipamento  Equipamento?   @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)
  projeto      Projeto?       @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder?  @relation("AlertasMargemOS", fields: [serviceOrderId], references: [id], onDelete: Cascade)
  visualizador Usuario?       @relation("AlertaVisualizador", fields: [visualizadoPor], references: [id], onDelete: SetNull)
  resolvedor   Usuario?       @relation("AlertaResolvedor", fields: [resolvidoPor], references: [id], onDelete: SetNull)

  @@index([ativo, prioridade, dataAlerta])
  @@index([tipo])
  @@index([materialId])
  @@index([equipamentoId])
  @@index([projetoId])
  @@index([serviceOrderId])
  @@map("alertas_estoque")
}

model Compra {
  id              Int           @id @default(autoincrement())
  fornecedorId    Int?          @map("fornecedor_id")
  numeroNf        String?       @map("numero_nf") @db.VarChar(60)
  dataCompra      DateTime      @map("data_compra") @db.Date
  dataEntrega     DateTime?     @map("data_entrega") @db.Date
  tipo            Compra_tipo
  projetoId       Int?          @map("projeto_id")
  valorTotal      Decimal       @default(0) @map("valor_total") @db.Decimal(14, 2)
  desconto        Decimal?      @db.Decimal(14, 2)
  frete           Decimal?      @db.Decimal(14, 2)
  formaPagamento  String?       @map("forma_pagamento") @db.VarChar(60)
  status          Compra_status @default(PENDENTE)
  observacoes     String?       @db.Text
  criadoEm        DateTime      @default(now()) @map("criado_em")
  atualizadoEm    DateTime?     @updatedAt @map("atualizado_em")
  criadoPor       Int?          @map("criado_por")
  purchaseOrderId Int?          @map("purchase_order_id")

  fornecedor    Fornecedor?    @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  projeto       Projeto?       @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  criador       Usuario?       @relation("CompraCriador", fields: [criadoPor], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  itens   CompraItem[]
  expense Expense? // Despesa gerada ao receber a compra

  @@index([fornecedorId])
  @@index([projetoId])
  @@index([status])
  @@index([dataCompra])
  @@index([purchaseOrderId])
  @@map("compras")
}

model CompraItem {
  id                  Int             @id @default(autoincrement())
  compraId            Int             @map("compra_id")
  tipoItem            CompraItem_tipo @map("tipo_item")
  materialId          Int?            @map("material_id")
  equipamentoId       Int?            @map("equipamento_id")
  materialEmbalagemId Int?            @map("material_embalagem_id")
  loteId              Int?            @map("lote_id")
  quantidade          Decimal         @db.Decimal(14, 3)
  custoUnitario       Decimal         @map("custo_unitario") @db.Decimal(14, 2)
  custoTotal          Decimal?        @map("custo_total") @db.Decimal(14, 2) // Computed column
  dataRecebimento     DateTime?       @map("data_recebimento")
  recebidoPor         Int?            @map("recebido_por")

  compra            Compra             @relation(fields: [compraId], references: [id], onDelete: Cascade)
  material          Material?          @relation(fields: [materialId], references: [id], onDelete: SetNull)
  equipamento       Equipamento?       @relation(fields: [equipamentoId], references: [id], onDelete: SetNull)
  materialEmbalagem MaterialEmbalagem? @relation(fields: [materialEmbalagemId], references: [id], onDelete: SetNull)
  lote              MaterialLote?      @relation(fields: [loteId], references: [id], onDelete: SetNull)
  recebedor         Usuario?           @relation("CompraItemRecebedor", fields: [recebidoPor], references: [id], onDelete: SetNull)

  @@index([compraId])
  @@index([tipoItem])
  @@map("compras_itens")
}

