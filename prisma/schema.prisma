// ===================================
// SERVICE ORDERS MODULE (V3.1)
// ===================================

enum ServiceOrderStatus {
  DRAFT // Rascunho
  SCHEDULED // Agendado, materiais reservados
  IN_PROGRESS // Técnico executando
  COMPLETED // Serviço feito
  AWAITING_PAYMENT // Invoice gerado
  CLOSED // Pagamento confirmado
  WRITE_OFF // Perda contábil
  CANCELED // Cancelada
}

enum ServiceOrderMaterialStatus {
  PENDING // Aguardando alocação
  NEEDS_PURCHASE // Sem estoque
  RESERVED // Bloqueado (decrementado)
  CONSUMED // Baixado contabilmente
  RETURNED // Devolvido
}

enum MaterialSupplyType {
  CLIENT_PROVIDES // Cliente fornece
  COMPANY_PROVIDES // Empresa fornece
}

enum ScheduleType {
  FIXED // Data fixa
  FLEXIBLE // Janela de datas
}

enum ChecklistItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
}

// S1: Canonical priority values — must match frontend enum everywhere
enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

model ServiceOrder {
  id           Int    @id @default(autoincrement())
  ticketNumber String @unique @db.VarChar(50)

  // Client and Location
  clienteId           Int
  sameClientAddress   Boolean @default(true)
  serviceAddressLine1 String? @db.VarChar(200)
  serviceAddressLine2 String? @db.VarChar(200)
  serviceCity         String? @db.VarChar(100)
  serviceState        String? @db.VarChar(50)
  serviceZip          String? @db.VarChar(20)
  servicePhone        String? @db.VarChar(30)
  serviceContactName  String? @db.VarChar(100)

  // End Client / On-site Contact (e.g. homeowner when client is a GC)
  endClientName  String? @db.VarChar(150)
  endClientPhone String? @db.VarChar(30)
  endClientEmail String? @db.VarChar(150)
  endClientNotes String? @db.Text

  // Scheduling
  scheduleType      ScheduleType @default(FIXED)
  scheduledDate     DateTime?
  scheduleDateStart DateTime?
  scheduleDateEnd   DateTime?

  // Scope and Estimate
  title          String   @db.VarChar(200)
  description    String?  @db.Text
  estimatedHours Decimal? @db.Decimal(5, 2)
  hourlyRate     Decimal? @db.Decimal(10, 2)

  // Materials
  materialSupply MaterialSupplyType @default(COMPANY_PROVIDES)

  // Assigned Worker
  assignedWorkerId Int? @map("assigned_worker_id")

  // Status and Lifecycle
  status   ServiceOrderStatus @default(DRAFT)
  priority ServiceOrderPriority?

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  closedAt     DateTime?
  canceledAt   DateTime?
  writtenOffAt DateTime?

  // Audit
  createdById        Int?
  closedById         Int?
  canceledById       Int?
  writtenOffById     Int?
  cancellationReason String? @db.VarChar(500)
  writeOffReason     String? @db.VarChar(500)

  // Notes
  techNotes   String? @db.Text
  clientNotes String? @db.Text

  // Client Signature
  clientSignatureUrl String? @map("client_signature_url") @db.VarChar(500)

  // Financial
  invoiceId     Int?    @unique
  total         Decimal @default(0) @db.Decimal(12, 2)
  laborTotal    Decimal @default(0) @db.Decimal(12, 2)
  materialTotal Decimal @default(0) @db.Decimal(12, 2)

  // Agreed Client Price + Estimates (Fase 1)
  agreedClientPrice Decimal? @map("agreed_client_price") @db.Decimal(12, 2)
  materialEstimate  Decimal? @map("material_estimate") @db.Decimal(12, 2)
  laborEstimate     Decimal? @map("labor_estimate") @db.Decimal(12, 2)
  marginStatus      String   @default("OK") @map("margin_status") @db.VarChar(20) // OK|WARNING|ALERT|CRITICAL|LOSS

  // Tax Classification (Fase 2)
  propertyType    PropertyType?    @default(RESIDENTIAL) @map("property_type")
  serviceCategory ServiceCategory? @default(REPAIR)      @map("service_category")
  contractType    ContractType?    @default(LUMP_SUM)    @map("contract_type")

  // Project link
  projetoId        Int?
  warrantyTicketId Int? @unique @map("warranty_ticket_id")

  // Relations
  Cliente              Cliente         @relation(fields: [clienteId], references: [id])
  Invoice              Invoice?        @relation(fields: [invoiceId], references: [id])
  Projeto              Projeto?        @relation(fields: [projetoId], references: [id])
  warrantyTicketOrigin WarrantyTicket? @relation("ServiceOrderWarrantyOrigin", fields: [warrantyTicketId], references: [id], onDelete: SetNull)
  AssignedWorker       Worker?         @relation("ServiceOrdersAssignedWorker", fields: [assignedWorkerId], references: [id])

  CreatedBy    Usuario? @relation("ServiceOrdersCreated", fields: [createdById], references: [id])
  ClosedBy     Usuario? @relation("ServiceOrdersClosed", fields: [closedById], references: [id])
  CanceledBy   Usuario? @relation("ServiceOrdersCanceled", fields: [canceledById], references: [id])
  WrittenOffBy Usuario? @relation("ServiceOrdersWrittenOff", fields: [writtenOffById], references: [id])

  materials                  ServiceOrderMaterial[]
  workEntries                WorkEntry[]
  scopeItems                 ServiceOrderScopeItem[]
  history                    ServiceOrderHistory[]
  attachments                ServiceOrderAttachment[]
  expenses                   Expense[]               @relation("ServiceOrderExpenses") // F1.2
  purchaseOrders             PurchaseOrder[]
  changeOrders               ChangeOrder[]
  warrantyTickets            WarrantyTicket[]        @relation("WarrantyTicketServiceOrder")
  warrantyTicketsCreatedFrom WarrantyTicket[]        @relation("WarrantyTicketServiceOrderCreated")

  // Workforce Module (v2)
  assignments    Assignment[]
  checklistItems ServiceOrderChecklistItem[]
  technicians    ServiceOrderTechnician[]
  alertasMargemOS AlertaEstoque[]           @relation("AlertasMargemOS")

  @@index([clienteId])
  @@index([status])
  @@index([assignedWorkerId])
  @@index([scheduledDate])
  @@index([createdAt])
  @@index([clienteId, status])
  @@index([assignedWorkerId, status])
  @@map("service_orders")
}

model ServiceOrderMaterial {
  id             Int  @id @default(autoincrement())
  serviceOrderId Int
  changeOrderId  Int?
  materialId     Int?

  // Identification
  name        String  @db.VarChar(200)
  unit        String? @db.VarChar(20)
  externalSku String? @db.VarChar(50)

  // Quantities
  quantityPlanned  Decimal @db.Decimal(12, 3)
  quantityUsed     Decimal @default(0) @db.Decimal(12, 3)
  quantityReturned Decimal @default(0) @db.Decimal(12, 3)

  // Costs (V3.1 #1)
  unitCostEstimated Decimal? @db.Decimal(12, 2)
  unitCostActual    Decimal? @db.Decimal(12, 2)
  unitPrice         Decimal? @db.Decimal(12, 2)

  // Tax (default shown in UI as 8.25% Texas — nullable: null = not yet specified)
  hasTax  Boolean?
  taxRate Decimal? @db.Decimal(5, 2) // e.g. 8.25 for 8.25%

  // Status
  status     ServiceOrderMaterialStatus @default(PENDING)
  flowStatus MaterialFlowStatus?        @map("flow_status")

  // Timestamps
  reservedAt DateTime?
  consumedAt DateTime?
  returnedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  ServiceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  ChangeOrder  ChangeOrder? @relation("ChangeOrderServiceOrderMaterials", fields: [changeOrderId], references: [id], onDelete: SetNull)
  Material     Material?    @relation(fields: [materialId], references: [id])
  attachments  ServiceOrderAttachment[]
  receiptLinks AttachmentMaterial[]
  // Field purchase tracking: links to the Expense created when technician purchases externally
  fieldExpenseId Int?     @map("field_expense_id")
  fieldExpense   Expense? @relation("FieldPurchaseExpense", fields: [fieldExpenseId], references: [id], onDelete: SetNull)

  // Return tracking
  returnDestination ReturnDestination? @map("return_destination")
  refundAmount      Decimal?           @map("refund_amount") @db.Decimal(12, 2)

  @@index([serviceOrderId])
  @@index([changeOrderId])
  @@index([materialId])
  @@index([fieldExpenseId])
  @@index([status])
  @@index([serviceOrderId, flowStatus], name: "idx_somat_service_order_flow")
  @@index([name, unit])
  @@map("service_order_materials")
}

model ServiceOrderTechnician {
  serviceOrderId Int
  workerId       Int      @map("worker_id")
  addedAt        DateTime @default(now())
  addedById      Int?

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  worker       Worker       @relation("ServiceOrderTechniciansWorker", fields: [workerId], references: [id])
  addedBy      Usuario?     @relation("ServiceOrderTechnicianAddedBy", fields: [addedById], references: [id])

  @@id([serviceOrderId, workerId])
  @@index([serviceOrderId])
  @@index([workerId])
  @@map("service_order_technicians")
}

model WorkEntry {
  id             Int @id @default(autoincrement())
  serviceOrderId Int
  workerId       Int @map("worker_id")

  // DateTime precision (V3.1)
  startedAt DateTime
  endedAt   DateTime

  // Values
  hourlyRate   Decimal @db.Decimal(10, 2)
  totalMinutes Int
  totalCost    Decimal @db.Decimal(10, 2)

  notes     String?  @db.Text
  createdAt DateTime @default(now())

  // Relations
  ServiceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  Worker       Worker       @relation("WorkerWorkEntries", fields: [workerId], references: [id])

  @@index([serviceOrderId])
  @@index([workerId])
  @@map("work_entries")
}

// === V3.2 NEW MODELS ===

model ServiceOrderScopeItem {
  id             Int             @id @default(autoincrement())
  serviceOrderId Int
  changeOrderId  Int?
  sortOrder      Int             @default(0)
  description    String          @db.VarChar(500)
  status         ScopeItemStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  ServiceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  ChangeOrder  ChangeOrder? @relation("ChangeOrderServiceOrderScopeItems", fields: [changeOrderId], references: [id], onDelete: SetNull)

  @@unique([serviceOrderId, sortOrder])
  @@index([serviceOrderId])
  @@index([changeOrderId])
  @@map("service_order_scope_items")
}

model ServiceOrderHistory {
  id             Int                 @id @default(autoincrement())
  serviceOrderId Int
  eventType      HistoryEventType
  fromStatus     ServiceOrderStatus?
  toStatus       ServiceOrderStatus?
  reason         String?             @db.VarChar(500)
  metadata       Json?
  createdById    Int?
  createdAt      DateTime            @default(now())

  ServiceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  CreatedBy    Usuario?     @relation("ServiceOrderHistoryCreated", fields: [createdById], references: [id])

  @@index([serviceOrderId])
  @@index([createdAt])
  @@index([serviceOrderId, createdAt(sort: Desc)])
  @@map("service_order_history")
}

enum ScopeItemStatus {
  PENDING
  DONE
  BLOCKED
}

enum HistoryEventType {
  CREATED
  STATUS_CHANGED
  CANCELED
  REOPENED
  TECH_ASSIGNED
  MATERIAL_ADDED
  WORK_ENTRY_ADDED
  // S2: new events for audit trail completeness
  INVOICE_GENERATED
  MATERIAL_RESERVED
  MATERIAL_CONSUMED
  MATERIAL_RETURNED
  TECHNICIAN_ADDED
  TECHNICIAN_REMOVED
}

