// ============================================================================
// MÓDULO: CONTAS BANCÁRIAS
// ============================================================================

model BankAccount {
  id        Int @id @default(autoincrement())
  empresaId Int

  // Informações da Conta
  nome    String // Nome identificador da conta
  banco   String // Nome do banco
  agencia String // Número da agência
  conta   String // Número da conta
  digito  String? // Dígito verificador
  tipo    TipoConta @default(CORRENTE)

  // Saldos e Controle
  saldoAtual    Decimal  @default(0.00) @db.Decimal(15, 2)
  saldoInicial  Decimal  @default(0.00) @db.Decimal(15, 2) // Saldo na abertura
  limiteCredito Decimal? @db.Decimal(15, 2) // Limite para contas com cheque especial

  // Status
  ativo     Boolean @default(true)
  principal Boolean @default(false) // Conta principal da empresa

  // Informações Adicionais
  observacoes       String?   @db.Text
  ultimaConciliacao DateTime? // Última vez que foi reconciliada

  // Metadata
  metadata     Json? // Dados extras (API banco, tokens, etc)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations
  empresa       Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  transactions  BankTransaction[]
  transfersFrom BankTransfer[]    @relation("TransferFrom")
  transfersTo   BankTransfer[]    @relation("TransferTo")
  ownerCompensations OwnerCompensation[]

  @@unique([empresaId, banco, agencia, conta])
  @@index([empresaId, ativo])
  @@index([tipo])
  @@map("bank_accounts")
}

model BankTransaction {
  id        Int @id @default(autoincrement())
  accountId Int
  empresaId Int

  // Informações da Transação
  tipo      TipoTransacao
  categoria String? // Categoria da transação
  valor     Decimal       @db.Decimal(15, 2)
  descricao String

  // Dados Bancários
  documento      String? // Número documento/cheque
  dataTransacao  DateTime // Data efetiva da transação
  dataLancamento DateTime @default(now()) // Data registro no sistema

  // Controle e Reconciliação
  saldoAnterior     Decimal   @db.Decimal(15, 2)
  saldoPosterior    Decimal   @db.Decimal(15, 2)
  reconciliada      Boolean   @default(false)
  dataReconciliacao DateTime?

  // Integrações
  revenueId  Int? // Link para Receita (se aplicável)
  expenseId  Int? // Link para Despesa (se aplicável)
  transferId Int? // Link para Transferência (se aplicável)

  // Metadata
  comprovante  String? // URL do comprovante
  observacoes  String?  @db.Text
  metadata     Json? // Dados extras da API bancária
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations
  account  BankAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  empresa  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  revenue  Revenue?      @relation(fields: [revenueId], references: [id], onDelete: SetNull)
  expense  Expense?      @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  transfer BankTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([accountId, dataTransacao])
  @@index([empresaId, dataTransacao])
  @@index([tipo, reconciliada])
  @@index([categoria])
  @@map("bank_transactions")
}

model BankTransfer {
  id        Int @id @default(autoincrement())
  empresaId Int

  // Contas Envolvidas
  fromAccountId Int
  toAccountId   Int

  // Informações da Transferência
  valor     Decimal             @db.Decimal(15, 2)
  descricao String
  status    StatusTransferencia @default(PENDENTE)

  // Datas
  dataAgendamento DateTime  @default(now())
  dataExecucao    DateTime? // Quando foi efetivamente executada
  dataConclusao   DateTime? // Quando foi concluída/confirmada

  // Controle
  tentativas     Int     @default(0)
  ultimaResposta String? @db.Text // Resposta da última tentativa
  processadoPor  Int? // Usuário que processou

  // Metadata
  comprovante  String? // URL do comprovante
  observacoes  String?  @db.Text
  metadata     Json? // Dados extras
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations
  empresa      Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fromAccount  BankAccount       @relation("TransferFrom", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount    BankAccount       @relation("TransferTo", fields: [toAccountId], references: [id], onDelete: Restrict)
  transactions BankTransaction[]

  @@index([empresaId, status])
  @@index([fromAccountId, dataAgendamento])
  @@index([toAccountId, dataAgendamento])
  @@index([status, dataAgendamento])
  @@map("bank_transfers")
}

// Enums para Contas Bancárias

enum TipoConta {
  CORRENTE // Conta corrente
  POUPANCA // Conta poupança
  INVESTIMENTO // Conta investimento
  CAIXA // Caixa físico (não é banco)
  CARTEIRA_DIGITAL // PicPay, Mercado Pago, etc
}

enum TipoTransacao {
  CREDITO // Entrada de dinheiro
  DEBITO // Saída de dinheiro
  TRANSFERENCIA_ENTRADA // Recebimento de transferência
  TRANSFERENCIA_SAIDA // Envio de transferência
  TAXA // Taxa bancária
  JUROS // Juros (crédito ou débito)
  ESTORNO // Estorno de transação
}

enum StatusTransferencia {
  PENDENTE // Aguardando processamento
  PROCESSANDO // Em processamento
  CONCLUIDA // Concluída com sucesso
  CANCELADA // Cancelada pelo usuário
  FALHOU // Falhou no processamento
  ESTORNADA // Estornada
}



// ============================================================================
// MÓDULO: HABILIDADES & DOCUMENTOS (vinculados ao Worker)
// ============================================================================

model HabilidadeColaborador {
  id Int @id @default(autoincrement())

  workerId Int? @map("worker_id")

  habilidade  String
  nivel       String?
  certificado Boolean?  @default(false)
  certExpiry  DateTime? @map("cert_expiry")

  worker Worker? @relation("WorkerHabilidades", fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("habilidades_colaborador")
}

model DocumentoColaborador {
  id Int @id @default(autoincrement())

  workerId Int? @map("worker_id")

  nome      String
  url       String
  tipo      String?
  expiresAt DateTime? @map("expires_at")

  criadoEm DateTime @default(now())

  worker Worker? @relation("WorkerDocumentos", fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("documentos_colaborador")
}

// ============================================================================
// MÓDULO: WORKFORCE - WORKERS (1099 Contractors / Vendors)
// ============================================================================

model Worker {
  id Int @id @default(autoincrement())

  // Login (opcional)
  usuarioId Int? @unique @map("usuario_id")

  // Dados cadastrais
  name            String  @db.VarChar(200)
  email           String? @db.VarChar(200)
  emailNormalized String? @unique @map("email_normalized") @db.VarChar(200)
  phone           String? @db.VarChar(30)

  // Endereço
  addressLine1 String? @map("address_line1") @db.VarChar(200)
  addressLine2 String? @map("address_line2") @db.VarChar(100)
  city         String? @db.VarChar(100)
  state        String? @db.VarChar(50)
  zip          String? @db.VarChar(20)

  // Tipo: INDIVIDUAL ou COMPANY
  type WorkerType @default(INDIVIDUAL)

  // Campos para COMPANY (LLC, Corp, etc)
  companyName String? @map("company_name") @db.VarChar(200)
  ein         String? @unique @db.VarChar(20)

  // Status
  status WorkerStatus @default(ACTIVE)

  // F2.1: Classificação fiscal
  classification WorkerClassification @default(CONTRACTOR_1099) @map("classification")

  // Taxa padrão (pode ser sobrescrita no Assignment)
  defaultHourlyRate Decimal? @map("default_hourly_rate") @db.Decimal(10, 2)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  usuario          Usuario?                @relation(fields: [usuarioId], references: [id])
  financialProfile WorkerFinancialProfile?
  assignments      Assignment[]
  payables         Payable[]
  // Reutiliza tabelas existentes com FK adicional
  habilidades      HabilidadeColaborador[] @relation("WorkerHabilidades")
  documentos       DocumentoColaborador[]  @relation("WorkerDocumentos")

  // Relations - Compliance (F1.3)
  taxProfiles VendorTaxProfile[] @relation("WorkerTaxProfiles")
  insurances  VendorInsurance[]  @relation("WorkerInsurances")
  licenses    VendorLicense[]    @relation("WorkerLicenses")

  // F2.2: Subcontract Agreements
  subcontracts SubcontractAgreement[] @relation("WorkerSubcontracts")

  // F2.3: Lien Waivers
  lienWaivers LienWaiver[] @relation("WorkerLienWaivers")

  // F4.2A: Punch List
  projectPunchItemsAssigned ProjectPunchItem[] @relation("ProjectPunchItemAssignedWorker")
  warrantyTicketsAssigned   WarrantyTicket[]   @relation("WarrantyTicketAssignedWorker")

  // Tax Compliance: Owner Compensation
  ownerCompensations OwnerCompensation[]

  // Service Orders
  serviceOrdersAssigned  ServiceOrder[]           @relation("ServiceOrdersAssignedWorker")
  serviceOrderTeam       ServiceOrderTechnician[] @relation("ServiceOrderTechniciansWorker")
  workEntries            WorkEntry[]              @relation("WorkerWorkEntries")

  @@index([status])
  @@index([type])
  @@map("workers")
}

model WorkerFinancialProfile {
  id       Int @id @default(autoincrement())
  workerId Int @unique @map("worker_id")

  // Dados NÃO sensíveis (sempre retornados no GET padrão)
  paymentMethod PaymentMethod @default(CHECK) @map("payment_method")
  payeeName     String?       @map("payee_name") @db.VarChar(200)
  accountLast4  String?       @map("account_last4") @db.VarChar(4)
  taxIdLast4    String?       @map("tax_id_last4") @db.VarChar(4)
  notes         String?       @db.Text

  // Dados sensíveis (CRIPTOGRAFADOS, nullable)
  // Só retornados via /api/workforce/workers/:id/sensitive
  encryptedRouting String? @map("encrypted_routing") @db.Text
  encryptedAccount String? @map("encrypted_account") @db.Text
  encryptedTaxId   String? @map("encrypted_tax_id") @db.Text

  // Preferências de pagamento
  preferredPayday String? @map("preferred_payday") @db.VarChar(20)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_financial_profiles")
}

enum WorkerType {
  INDIVIDUAL
  COMPANY
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkerClassification {
  W2_EMPLOYEE
  CONTRACTOR_1099
  SUBCONTRACTOR
  OWNER_OPERATOR
}

// ============================================================================
// MÓDULO: WORKFORCE - ASSIGNMENTS & TIMESHEETS (v2)
// ============================================================================

model Assignment {
  id Int @id @default(autoincrement())

  // workerId OBRIGATÓRIO (Etapa 2 concluída)
  workerId Int @map("worker_id")

  // Alvo (pelo menos 1 deve estar preenchido)
  jobId     Int? @map("job_id") // ServiceOrder ID
  projectId Int? @map("project_id") // Projeto ID

  // Tipo e Rate
  payType         PayType  @default(HOURLY) @map("pay_type")
  costRateHourly  Decimal? @map("cost_rate_hourly") @db.Decimal(10, 2)
  fixedCostAmount Decimal? @map("fixed_cost_amount") @db.Decimal(12, 2)

  // Período (effectiveFrom na unique para histórico de rates)
  effectiveFrom DateTime  @default(now()) @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  // Status
  status AssignmentStatus @default(ACTIVE)

  // Metadados
  role  String? @db.VarChar(100)
  notes String? @db.Text

  // Audit
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  createdById Int?             @map("created_by_id")
  source      AssignmentSource @default(MANUAL)

  worker     Worker        @relation(fields: [workerId], references: [id])
  job        ServiceOrder? @relation(fields: [jobId], references: [id])
  project    Projeto?      @relation(fields: [projectId], references: [id])
  timesheets Timesheet[]
  milestones Milestone[]

  // CHAVE ÚNICA
  // Nota: índice composto precisa de pelo menos um não-null
  @@index([workerId])
  @@index([jobId])
  @@index([projectId])
  @@index([status])
  @@map("assignments")
}

model Timesheet {
  id           Int @id @default(autoincrement())
  assignmentId Int @map("assignment_id")

  // Período
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date

  // Workflow
  status TimesheetStatus @default(DRAFT)

  // Submissão
  submittedAt   DateTime? @map("submitted_at")
  submittedById Int?      @map("submitted_by_id")

  // Aprovação
  approvedAt   DateTime? @map("approved_at")
  approvedById Int?      @map("approved_by_id")

  // Totais (calculados)
  totalHours Decimal @default(0) @map("total_hours") @db.Decimal(8, 2)
  totalCost  Decimal @default(0) @map("total_cost") @db.Decimal(12, 2)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  assignment Assignment       @relation(fields: [assignmentId], references: [id])
  entries    TimesheetEntry[]

  @@unique([assignmentId, periodStart, periodEnd])
  @@index([status])
  @@index([periodStart])
  @@map("timesheets")
}

model TimesheetEntry {
  id          Int @id @default(autoincrement())
  timesheetId Int @map("timesheet_id")

  // Dados
  date      DateTime @db.Date
  hours     Decimal  @db.Decimal(5, 2)
  jobId     Int?     @map("job_id")
  projectId Int?     @map("project_id")
  note      String?  @db.Text

  // Status individual
  status TimesheetEntryStatus @default(DRAFT)

  // Migração (para backfill de WorkEntry)
  migratedFrom String? @map("migrated_from") @db.VarChar(50)
  migratedId   Int?    @map("migrated_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@index([timesheetId])
  @@index([date])
  @@map("timesheet_entries")
}

model Milestone {
  id           Int @id @default(autoincrement())
  assignmentId Int @map("assignment_id")

  // Alvo
  jobId     Int? @map("job_id")
  projectId Int? @map("project_id")

  // Dados
  description String  @db.VarChar(500)
  amount      Decimal @db.Decimal(12, 2)

  // Workflow
  status MilestoneStatus @default(DRAFT)

  // Aprovação
  approvedAt   DateTime? @map("approved_at")
  approvedById Int?      @map("approved_by_id")

  // Audit
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@index([assignmentId])
  @@index([status])
  @@map("milestones")
}

model Payable {
  id Int @id @default(autoincrement())

  // workerId OBRIGATÓRIO (Etapa 2 concluída)
  workerId Int @map("worker_id")

  // Período
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")

  // Status
  status      PayableStatus @default(PENDING)
  totalAmount Decimal       @map("total_amount") @db.Decimal(12, 2)

  // Origem
  createdFrom PayableSource @map("created_from")
  description String?       @db.VarChar(500)

  // Pagamento
  paidAt        DateTime?      @map("paid_at")
  paidById      Int?           @map("paid_by_id")
  paymentMethod PaymentMethod? @map("payment_method")
  paymentRef    String?        @map("payment_ref") @db.VarChar(100)

  // Link com Expense (1:1 após PAID)
  expenseId Int? @unique @map("expense_id")

  // Audit
  createdAt    DateTime  @default(now()) @map("created_at")
  createdById  Int?      @map("created_by_id")
  approvedAt   DateTime? @map("approved_at")
  approvedById Int?      @map("approved_by_id")

  // Relations
  worker    Worker            @relation(fields: [workerId], references: [id])
  lineItems PayableLineItem[]

  @@index([workerId])
  @@index([status])
  @@map("payables")
}

model PayableLineItem {
  id        Int @id @default(autoincrement())
  payableId Int @map("payable_id")

  // Alvo
  jobId     Int? @map("job_id")
  projectId Int? @map("project_id")

  // Dados
  description String  @db.VarChar(300)
  quantity    Decimal @db.Decimal(8, 2)
  unitCost    Decimal @map("unit_cost") @db.Decimal(10, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(12, 2)

  // Origem
  sourceType PayableSourceType @map("source_type")
  sourceId   Int               @map("source_id")

  payable Payable @relation(fields: [payableId], references: [id], onDelete: Cascade)

  @@index([payableId])
  @@map("payable_line_items")
}

// ENUMS WORKFORCE

enum PayType {
  HOURLY
  FIXED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AssignmentSource {
  MANUAL
  COMPAT_LAYER
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum TimesheetEntryStatus {
  DRAFT
  APPROVED
  LOCKED
}

enum MilestoneStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum PayableStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum PayableSource {
  TIMESHEET
  MILESTONE
  MANUAL
}

enum PayableSourceType {
  TIMESHEET_ENTRY
  MILESTONE
}

enum PaymentMethod {
  CHECK
  ZELLE
  ACH
  CASH
  WIRE
  OTHER
}

model ExpenseRecurrence {
  id             Int                   @id @default(autoincrement())
  expenseId      Int                   @unique
  frequencia     FrequenciaRecorrencia
  diaVencimento  Int
  dataInicio     DateTime
  dataFim        DateTime?
  proximaGeracao DateTime
  ativo          Boolean               @default(true)
  criadoEm       DateTime              @default(now())

  despesa Expense?  @relation("ExpenseToRecurrence")
  geradas Expense[] @relation("ExpenseRecurrenceOrigin")

  @@index([proximaGeracao])
  @@map("expense_recurrences")
