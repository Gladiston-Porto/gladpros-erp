model Material {
  id           Int      @id @default(autoincrement())
  codigo       String   @unique @db.VarChar(60)
  nome         String   @db.VarChar(150)
  descricao    String?  @db.Text
  categoriaId  Int?     @map("categoria_id")
  unidadeId    Int      @map("unidade_id")
