generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AnexoProposta {
  id         Int      @id @default(autoincrement())
  propostaId Int
  filename   String   @db.VarChar(255)
  filepath   String   @db.VarChar(500)
  mime       String   @db.VarChar(100)
  uploadedBy Int
  criadoEm   DateTime @default(now())
  descricao  String?  @db.Text
  privado    Boolean  @default(false)
  Proposta   Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([propostaId])
}

model AuditLog {
  id         String   @id
  userId     Int
  entidade   String
  entidadeId String
  acao       String
  diff       String?  @db.LongText
  timestamp  DateTime @default(now())
  Usuario    Usuario  @relation(fields: [userId], references: [id])

  @@index([entidade, entidadeId])
  @@index([timestamp])
  @@index([userId])
}

model Auditoria {
  id         Int            @id @default(autoincrement())
  tabela     String         @db.VarChar(64)
  registroId Int
  acao       Auditoria_acao
  usuarioId  Int?
  ip         String?        @db.VarChar(45)
  payload    String?        @db.LongText
  criadoEm   DateTime       @default(now())
  Usuario    Usuario?       @relation(fields: [usuarioId], references: [id])

  @@index([tabela, registroId, criadoEm])
  @@index([tabela, registroId])
  @@index([usuarioId])
}

model Empresa {
  id           Int      @id @default(autoincrement())
  nome         String   @db.VarChar(200)
  razaoSocial  String   @db.VarChar(200)
  cnpj         String?  @unique @db.VarChar(18)
  email        String?  @db.VarChar(255)
  telefone     String?  @db.VarChar(32)
  endereco     Json?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations - Receitas
  // Relations - Conteúdo existente...
  revenues          Revenue[]
  revenueCategories RevenueCategory[]

  // Relations - Despesas
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  purchaseOrders    PurchaseOrder[]

  // Relations - Contas Bancárias
  bankAccounts     BankAccount[]
  bankTransactions BankTransaction[]
  bankTransfers    BankTransfer[]

  // Regime tributário (US Federal Tax)
  tipoTributacao      TipoTributacao @default(LLC_DEFAULT)
  tipoTributacaoDesde DateTime?      @map("tipo_tributacao_desde")

  // US Address Standardization
  addressStreet String? @db.VarChar(255)
  addressUnit   String? @db.VarChar(50)
  addressCity   String? @db.VarChar(100)
  addressState  String? @default("TX") @db.VarChar(2)
  addressZip    String? @db.VarChar(20)
  addressCounty String? @db.VarChar(100)

  // Relations - Tax Compliance
  ownerCompensations    OwnerCompensation[]
  estimatedTaxPayments  EstimatedTaxPayment[]

  // Relations - Invoices
  invoices     Invoice[]

  @@index([ativo])
  @@map("empresas")
}

model Cliente {
  id           Int          @id @default(autoincrement())
  tipo         Cliente_tipo
  nomeCompleto String?
  razaoSocial  String?
  nomeFantasia String?
  email        String       @unique
  telefone     String       @db.VarChar(32)
  nomeChave    String
  endereco     Json? // Deprecated: Use specific address fields below

  // US Address Standardization
  addressStreet String? @db.VarChar(255)
  addressUnit   String? @db.VarChar(50)
  addressCity   String? @db.VarChar(100)
  addressState  String? @default("TX") @db.VarChar(2)
  addressZip    String? @db.VarChar(20)
  addressCounty String? @db.VarChar(100)

  status          Cliente_status           @default(ATIVO)
  tipoDocumentoPF Cliente_tipoDocumentoPF?
  ssn             String?                  @db.VarChar(32)
  itin            String?                  @db.VarChar(32)
  ein             String?                  @db.VarChar(32)
  documentoEnc    String?
  docLast4        String?                  @db.VarChar(4)
  docHash         String?                  @unique @db.Char(64)
  // Tax Exemption Certificate (Fase 2)
  taxExemptCertNumber String?              @db.VarChar(50)
  taxExemptCertExpiry DateTime?
  taxExemptCertType   String?              @db.VarChar(50)
  taxExemptCertFileKey String?             @db.VarChar(255)
  observacoes     String?
  ativo           Boolean                  @default(true)
  criadoEm        DateTime                 @default(now())
  atualizadoEm    DateTime
  Proposta        Proposta[]
  Projetos        Projeto[]
  invoices        Invoice[]
  revenues        Revenue[]
  Estimations     Estimation[]
  ServiceOrders   ServiceOrder[] // V3.1
  warrantyTickets WarrantyTicket[]

  @@index([ativo])
  @@index([docLast4])
  @@index([nomeChave, telefone])
  @@index([status, tipo])
  @@index([addressZip])
  @@index([addressCounty])
  @@index([addressCity])
  @@index([addressState])
  @@index([addressCity, addressState])
}

// ============================================
// TAXATION MODULE (TEXAS COMPLIANCE)
// ============================================

enum TaxJurisdictionType {
  STATE
  COUNTY
  CITY
  SPECIAL_DISTRICT
}

model TaxRate {
  id               Int                 @id @default(autoincrement())
  name             String              @db.VarChar(100) // e.g., "Dallas County"
  jurisdictionType TaxJurisdictionType
  rate             Decimal             @db.Decimal(6, 4) // e.g., 0.0625, 0.0100
  code             String?             @unique @db.VarChar(50) // External tax code if needed
  active           Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([active])
  @@index([jurisdictionType])
}

// ============================================
// ESTIMATION & JOB COSTING (PRICEBOOK)
// ============================================

enum PricebookItemType {
  MATERIAL
  LABOR
  SERVICE
  EQUIPMENT
  FEE
}

enum PricebookMarkupStrategy {
  FIXED_MARGIN
  FIXED_PRICE
}

model PricebookCategory {
  id          Int                 @id @default(autoincrement())
  name        String              @db.VarChar(100)
  description String?             @db.Text
  parentId    Int?
  parent      PricebookCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    PricebookCategory[] @relation("CategoryHierarchy")
  items       PricebookItem[]

  @@map("pricebook_categories")
}

model PricebookItem {
  id          Int               @id @default(autoincrement())
  categoryId  Int?
  sku         String            @unique @db.VarChar(50)
  name        String            @db.VarChar(200)
  description String?           @db.Text
  type        PricebookItemType
  unit        String            @default("EA") @db.VarChar(20)

  // Costing
  unitCost Decimal @default(0) @db.Decimal(12, 4)

  // Pricing Strategy
  markupStrategy PricebookMarkupStrategy @default(FIXED_MARGIN)
  defaultMargin  Decimal                 @default(40.00) @db.Decimal(5, 2) // 40% margin default
  fixedPrice     Decimal?                @db.Decimal(12, 2)

  // Taxability
  taxable Boolean @default(true)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Category        PricebookCategory? @relation(fields: [categoryId], references: [id])
  EstimationItems EstimationItem[] // Relation to Estimation Items

  @@index([sku])
  @@index([type])
  @@index([active])
  @@map("pricebook_items")
}

model Estimation {
  id        Int    @id @default(autoincrement())
  projetoId Int? // Optional link to a Project
  clienteId Int // Link to Client
  status    String @default("DRAFT") // DRAFT, CONVERTED, ARCHIVED
  name      String @db.VarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  options EstimationOption[]
  Cliente Cliente            @relation(fields: [clienteId], references: [id])
  Projeto Projeto?           @relation(fields: [projetoId], references: [id])

  @@index([clienteId])
  @@map("estimations")
}

model EstimationOption {
  id           Int    @id @default(autoincrement())
  estimationId Int
  name         String @db.VarChar(100) // "Good", "Better", "Best"

  // Totals (Cached)
  totalCost   Decimal @default(0) @db.Decimal(15, 2)
  totalPrice  Decimal @default(0) @db.Decimal(15, 2)
  grossMargin Decimal @default(0) @db.Decimal(5, 2)

  items      EstimationItem[]
  Estimation Estimation       @relation(fields: [estimationId], references: [id], onDelete: Cascade)

  @@index([estimationId])
  @@map("estimation_options")
}

model EstimationItem {
  id                 Int  @id @default(autoincrement())
  estimationOptionId Int
  pricebookItemId    Int?

  // Snapshot data (in case Pricebook changes)
  sku         String? @db.VarChar(50)
  name        String  @db.VarChar(200)
  description String? @db.Text
  quantity    Decimal @db.Decimal(12, 3)
  unit        String  @db.VarChar(20)

  // Costing (Internal)
  unitCost  Decimal @db.Decimal(12, 2)
  totalCost Decimal @db.Decimal(15, 2)

  // Pricing (Customer Facing)
  markup     Decimal @default(0) @db.Decimal(7, 2) // Markup %
  margin     Decimal @default(0) @db.Decimal(7, 2) // Margin %
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(15, 2)

  taxable Boolean @default(true)

  PricebookItem PricebookItem?   @relation(fields: [pricebookItemId], references: [id])
  Option        EstimationOption @relation(fields: [estimationOptionId], references: [id], onDelete: Cascade)

  @@index([estimationOptionId])
  @@map("estimation_items")
}

model CodigoMFA {
  id        Int                @id @default(autoincrement())
  usuarioId Int
  codigo    String             @db.Char(64)
  tipoAcao  CodigoMFA_tipoAcao
  expiresAt DateTime
  usado     Boolean            @default(false)
  criadoEm  DateTime           @default(now())
  ip        String?            @db.VarChar(45)
  userAgent String?            @db.VarChar(255)
  Usuario   Usuario            @relation(fields: [usuarioId], references: [id])

  @@index([criadoEm])
  @@index([tipoAcao])
  @@index([usuarioId])
  @@index([usuarioId, tipoAcao], name: "idx_codigomfa_usuario_tipo")
}

model HistoricoSenha {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  senhaHash String
  criadaEm  DateTime @default(now())
  Usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @db.Char(64)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  Usuario   Usuario  @relation(fields: [userId], references: [id])

  @@index([tokenHash])
  @@index([userId])
}

model ProjetoLegacy {
  id           Int            @id @default(autoincrement())
  clienteId    Int
  propostaId   Int?           @unique
  origem       Projeto_origem @default(SEM_PROPOSTA)
  nome         String?
  status       String?        @default("INICIADO")
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime
  Proposta     Proposta?      @relation(fields: [propostaId], references: [id])

  @@index([clienteId])
  @@index([origem])
  @@map("Projeto")
}

model CatalogoItem {
  id          Int      @id @default(autoincrement())
  empresaId   Int      @default(1)
  codigo      String?  @db.VarChar(50)
  nome        String   @db.VarChar(300)
  descricao   String?  @db.Text
  categoria   String?  @db.VarChar(100)
  unidade     String   @default("unit") @db.VarChar(30)
  precoUnitario Decimal? @db.Decimal(12, 2)
  tipo        String   @default("servico") @db.VarChar(30) // servico | material | equipamento
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([empresaId])
  @@index([nome])
  @@index([categoria])
}

model Proposta {
  id                         Int                               @id @default(autoincrement())
  numeroProposta             String                            @unique @db.VarChar(20)
  clienteId                  Int
  dataCriacao                DateTime                          @default(now())
  tipoServico                String
  permite                    Proposta_permite
  quaisPermites              String?                           @db.Text
  condicoesPagamento         String?                           @db.LongText
  valorEstimado              Decimal?                          @db.Decimal(12, 2)
  moeda                      String                            @default("USD") @db.VarChar(3)
  status                     Proposta_status                   @default(RASCUNHO)
  enviadaParaOCliente        DateTime?
  assinaturaCliente          String?                           @db.VarChar(255)
  assinaturaResponsavel      String?                           @db.VarChar(255)
  assinadaEm                 DateTime?
  tempoParaAceite            Int?
  projetoId                  Int?                              @unique
  historicoAlteracoes        String?                           @db.LongText
  deletedAt                  DateTime?
  deletedBy                  Int?
  criadoEm                   DateTime                          @default(now())
  atualizadoEm               DateTime
  aprovacaoInternaFinanceira Boolean?                          @default(false)
  aprovacaoInternaTecnica    Boolean?                          @default(false)
  aprovadaEm                 DateTime?
  assinaturaImagem           String?                           @db.Text
  assinaturaIp               String?                           @db.VarChar(45)
  assinaturaTipo             Proposta_assinaturaTipo?          @default(CANVAS)
  assinaturaUserAgent        String?                           @db.Text
  atualizadoPor              Int?
  condicoesGerais            String?                           @db.Text
  contatoEmail               String                            @default("nao-informado@temp.com") @db.VarChar(255)
  contatoNome                String                            @default("Não informado") @db.VarChar(255)
  contatoTelefone            String?                           @db.VarChar(50)
  // End Client / On-site Contact
  endClientName              String?                           @db.VarChar(150)
  endClientPhone             String?                           @db.VarChar(30)
  endClientEmail             String?                           @db.VarChar(150)
  endClientNotes             String?                           @db.Text
  criadoPor                  Int?
  dataConversao              DateTime?
  descontosCondicionais      String?                           @db.Text
  descontosOfertados         Decimal?                          @db.Decimal(5, 2)
  descricaoEscopo            String                            @default("Escopo não detalhado") @db.Text
  exclusoes                  String?                           @db.Text
  formaPagamentoPreferida    Proposta_formaPagamentoPreferida?
  garantia                   String?                           @db.Text
  gatilhoFaturamento         Proposta_gatilhoFaturamento?      @default(NA_APROVACAO)
  inspecoesNecessarias       String?                           @db.Text
  instrucoesPagamento        String?                           @db.Text
  internalEstimate           String?                           @db.LongText
  janelaExecucaoPreferencial String?                           @db.Text
  localExecucaoEndereco      String                            @default("Endereço não informado") @db.Text
  marcosPagamento            String?                           @db.LongText
  motivo_cancelamento        String?                           @db.Text
  multaAtraso                String?                           @db.VarChar(100)
  normasReferencias          String?                           @db.Text
  observacoesInternas        String?                           @db.Text
  observacoesParaCliente     String?                           @db.Text
  opcoesAlternativas         String?                           @db.LongText
  percentualSinal            Decimal?                          @db.Decimal(5, 2)
  prazoExecucaoEstimadoDias  Int?
  precoPropostaCliente       Decimal?                          @db.Decimal(12, 2)
  responsavelConversao       Int?
  restricoesDeAcesso         String?                           @db.Text
  riscosIdentificados        String?                           @db.Text
  titulo                     String                            @default("Proposta sem título") @db.VarChar(500)
  tokenExpiresAt             DateTime?
  tokenPublico               String?                           @unique @db.VarChar(100)
  validadeProposta           DateTime?
  // Tax Classification (Fase 2 — used by salesTaxService)
  propertyType    PropertyType?    @default(RESIDENTIAL) @map("property_type")
  serviceCategory ServiceCategory? @default(REPAIR)      @map("service_category")
  contractType    ContractType?    @default(LUMP_SUM)    @map("contract_type")
  // Structured service address (Fase 3 — where the work happens, may differ from client address)
  serviceAddressLine1        String?  @db.VarChar(200)
  serviceAddressLine2        String?  @db.VarChar(100)
  serviceAddressCity         String?  @db.VarChar(100)
  serviceAddressState        String?  @default("TX") @db.VarChar(2)
  serviceAddressZip          String?  @db.VarChar(10)
  // Computed TX sales tax (Fase 3 — stored for display on proposal PDF/portal)
  taxScenario                String?  @db.VarChar(2)
  taxMode                    TaxMode? @default(NON_TAXABLE)
  taxRate                    Decimal? @db.Decimal(6, 4)
  taxAmount                  Decimal? @db.Decimal(12, 2)
  taxExplanation             String?  @db.Text
  taxRequiresReview          Boolean? @default(false)
  AnexoProposta              AnexoProposta[]
  Projeto                    ProjetoLegacy?
  Projetos                   Projeto[]                         @relation("PropostaProjetos")
  Cliente                    Cliente                           @relation(fields: [clienteId], references: [id])
  PropostaEtapa              PropostaEtapa[]
  PropostaLog                PropostaLog[]
  PropostaMaterial           PropostaMaterial[]
  Invoices                   Invoice[]

  @@index([clienteId])
  @@index([dataCriacao, id])
  @@index([status, dataCriacao, id])
  @@index([status])
}

model PropostaEtapa {
  id                   Int                  @id @default(autoincrement())
  propostaId           Int
  servico              String
  descricao            String               @db.Text
  status               PropostaEtapa_status @default(PLANEJADA)
  ordem                Int                  @default(0)
  custoMaoObraEstimado Decimal?             @db.Decimal(12, 2)
  dependencias         String?              @db.Text
  duracaoEstimadaHoras Decimal?             @db.Decimal(8, 2)
  quantidade           Decimal?             @db.Decimal(10, 2)
  unidade              String?              @db.VarChar(20)
  Proposta             Proposta             @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  invoiceItems         InvoiceItem[]

  @@index([propostaId])
}

model PropostaLog {
  id            String             @id
  propostaId    Int
  actorId       Int?
  action        PropostaLog_action
  oldJson       String?            @db.LongText
  newJson       String?            @db.LongText
  ip            String?            @db.VarChar(45)
  userAgent     String?            @db.Text
  correlationId String?            @db.VarChar(100)
  createdAt     DateTime           @default(now())
  Proposta      Proposta           @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([propostaId])
}

model PropostaMaterial {
  id                     Int                     @id @default(autoincrement())
  propostaId             Int
  estoqueItemId          Int?                    // Optional link to EstoqueItem for stock check
  codigo                 String?                 @db.VarChar(50)
  nome                   String
  quantidade             Decimal                 @default(0.000) @db.Decimal(12, 3)
  unidade                String?                 @db.VarChar(20)
  status                 PropostaMaterial_status @default(PLANEJADO)
  observacao             String?                 @db.Text
  precoUnitario          Decimal?                @db.Decimal(12, 2)
  moeda                  String                  @default("USD") @db.VarChar(3)
  totalItem              Decimal?                @db.Decimal(12, 2)
  fornecedorPreferencial String?                 @db.VarChar(255)
  Proposta               Proposta                @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  @@index([propostaId])
  @@index([estoqueItemId])
}

model PropostaTemplate {
  id            Int       @id @default(autoincrement())
  empresaId     Int       @default(1)
  nome          String    @db.VarChar(200)
  descricao     String?   @db.Text
  titulo        String?   @db.VarChar(300)
  escopo        String?   @db.LongText
  condicoes     String?   @db.LongText
  observacoes   String?   @db.LongText
  etapasJson    String?   @db.LongText
  materiaisJson String?   @db.LongText
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([empresaId])
  @@index([deletedAt])
}

model Projeto {
  id                    Int                          @id @default(autoincrement())
  propostaId            Int?                         @map("proposta_id")
  clienteId             Int                          @map("cliente_id")
  numeroProjeto         String                       @unique @map("numero_projeto") @db.VarChar(30)
  titulo                String                       @db.VarChar(200)
  descricao             String?                      @db.Text
  budgetBaseline        Json?                        @map("budget_baseline")
  baselineLockedAt      DateTime?                    @map("baseline_locked_at")
  baselineLockedBy      Int?                         @map("baseline_locked_by")
  status                Projeto_status               @default(planejado)
  dataInicioPrevista    DateTime?                    @map("data_inicio_prevista") @db.Date
  dataInicioReal        DateTime?                    @map("data_inicio_real") @db.Date
  dataConclusaoPrevista DateTime?                    @map("data_conclusao_prevista") @db.Date
  dataConclusaoReal     DateTime?                    @map("data_conclusao_real") @db.Date
  portalTokenHash       String?                      @unique @map("portal_token_hash") @db.VarChar(64)
  portalTokenCreatedAt  DateTime?                    @map("portal_token_created_at")
  portalTokenRevokedAt  DateTime?                    @map("portal_token_revoked_at")
  valorEstimado         Decimal?                     @map("valor_estimado") @db.Decimal(12, 2)
  custoPrevisto         Decimal?                     @map("custo_previsto") @db.Decimal(12, 2)
  custoReal             Decimal?                     @map("custo_real") @db.Decimal(12, 2)
  margemPrevista        Decimal?                     @map("margem_prevista") @db.Decimal(7, 2)
  margemReal            Decimal?                     @map("margem_real") @db.Decimal(7, 2)
  lucroPrevisto         Decimal?                     @map("lucro_previsto") @db.Decimal(12, 2)
  lucroReal             Decimal?                     @map("lucro_real") @db.Decimal(12, 2)
  responsavelId         Int?                         @map("responsavel_id")
  prioridade            Projeto_prioridade           @default(media)
  localidade            String?                      @db.VarChar(150)
  endereco              String?                      @db.Text
  // End Client / On-site Contact
  endClientName         String?                      @db.VarChar(150)
  endClientPhone        String?                      @db.VarChar(30)
  endClientEmail        String?                      @db.VarChar(150)
  endClientNotes        String?                      @db.Text
  criadoPor             Int                          @map("criado_por")
  atualizadoPor         Int?                         @map("atualizado_por")
  criadoEm              DateTime                     @default(now()) @map("criado_em")
  atualizadoEm          DateTime?                    @map("atualizado_em")
  Cliente               Cliente                      @relation(fields: [clienteId], references: [id])
  Proposta              Proposta?                    @relation("PropostaProjetos", fields: [propostaId], references: [id])
  Responsavel           Usuario?                     @relation("ProjetoResponsavel", fields: [responsavelId], references: [id], map: "projetos_responsavel_fk_custom")
  BaselineLockedByUser  Usuario?                     @relation("ProjetoBaselineLockedBy", fields: [baselineLockedBy], references: [id])
  CriadoPor             Usuario                      @relation("ProjetoCriadoPor", fields: [criadoPor], references: [id])
  AtualizadoPor         Usuario?                     @relation("ProjetoAtualizadoPor", fields: [atualizadoPor], references: [id])
  Etapas                ProjetoEtapa[]
  Materiais             ProjetoMaterial[]
  Anexos                ProjetoAnexo[]
  Historico             ProjetoHistorico[]
  Tarefas               ProjetoTarefa[]
  MovimentacoesEstoque  ProjetoMovimentacaoEstoque[]

  // Relações com módulo Estoque
  materiaisEstoque              ProjetoMaterialEstoque[] @relation("ProjetoMateriaisEstoque")
  equipamentosEstoque           ProjetoEquipamento[]
  movimentacoesMateriaisEstoque MaterialMovimentacao[]
  movimentacoesUnificadas       Movimentacao[]
  equipamentosAlocados          Equipamento[]
  alertasEstoque                AlertaEstoque[]
  comprasEstoque                Compra[]
  purchaseOrders                PurchaseOrder[]

  // Relações com módulo Financeiro
  invoices      Invoice[]
  expenses      Expense[]      @relation("ProjetoExpenses") // F1.2
  Estimations   Estimation[]
  ServiceOrders ServiceOrder[] // V3.1

  // Workforce Module (v2)
  assignments Assignment[]

  // F2.2: Subcontract Agreements
