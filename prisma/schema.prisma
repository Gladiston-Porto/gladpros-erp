  VENCIDA
  CANCELADA
}

enum FrequenciaRecorrencia {
  SEMANAL
  QUINZENAL
  MENSAL
  BIMESTRAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

// ==========================================
// MÓDULO: DESPESAS (Expenses)
// ==========================================

model Expense {
  id             Int            @id @default(autoincrement())
  empresaId      Int
  categoriaId    Int
  fornecedorId   Int? // Opcional - fornecedor/prestador
  descricao      String         @db.VarChar(255)
  valor          Decimal        @db.Decimal(10, 2)
  tipo           TipoDespesa
  formaPagamento FormaPagamento
  status         StatusDespesa  @default(PENDENTE)

  // Datas
  dataEmissao    DateTime
  dataVencimento DateTime
  dataPagamento  DateTime?

  // F1.2: Vínculo com Projeto e OS (Job Costing)
  projetoId          Int?                 @map("projeto_id")
  serviceOrderId     Int?                 @map("service_order_id")
  projectPermitId    Int?                 @unique @map("project_permit_id")
  isBillableToClient Boolean              @default(false) @map("is_billable_to_client")
  costCategory       ExpenseCostCategory? @map("cost_category")

  // Aprovação
  requerAprovacao Boolean @default(false)
  aprovacaoId     Int?    @unique

  // Anexos
  anexoUrl        String? @db.VarChar(500)
  numeroDocumento String? @db.VarChar(100)

  // Observações
  observacoes String? @db.Text

  // Vínculo com Compra (para despesas geradas de compras recebidas)
  compraId Int? @unique @map("compra_id")

  // F2.5: Link com Purchase Order (commitment tracking)
  purchaseOrderId Int? @map("purchase_order_id")

  // Metadata
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  criadoPor    Int?

  // Recorrência
  recorrente    Boolean             @default(false)
  recorrenciaId Int?                @unique
  recorrencia   ExpenseRecurrence?  @relation("ExpenseToRecurrence", fields: [recorrenciaId], references: [id])
  recorrencias  ExpenseRecurrence[] @relation("ExpenseRecurrenceOrigin")

  // Relations
  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  categoria        ExpenseCategory   @relation(fields: [categoriaId], references: [id])
  fornecedor       Fornecedor?       @relation(fields: [fornecedorId], references: [id])
  projeto          Projeto?          @relation("ProjetoExpenses", fields: [projetoId], references: [id], onDelete: SetNull)
  serviceOrder     ServiceOrder?     @relation("ServiceOrderExpenses", fields: [serviceOrderId], references: [id], onDelete: SetNull)
  projectPermit    ProjectPermit?    @relation(fields: [projectPermitId], references: [id], onDelete: SetNull)
  aprovacao        ExpenseApproval?
  usuario          Usuario?          @relation("ExpenseCriadoPor", fields: [criadoPor], references: [id])
  bankTransactions BankTransaction[]
  compra           Compra?           @relation(fields: [compraId], references: [id])
  purchaseOrder    PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  fieldPurchaseMaterials ServiceOrderMaterial[] @relation("FieldPurchaseExpense")

  // Refund tracking (when field-purchased materials are returned to store)
  refundAmount Decimal?  @map("refund_amount") @db.Decimal(10, 2)
  refundDate   DateTime? @map("refund_date")
  refundNotes  String?   @map("refund_notes") @db.VarChar(500)

  // Tax Compliance: Deductibility
  dedutivel           Boolean @default(true)
  percentualDedutivel Int?    @map("percentual_dedutivel") // null = 100%, 50 = meals, etc.

  // Indexes
  @@index([empresaId, status, dataVencimento])
  @@index([categoriaId])
  @@index([fornecedorId])
  @@index([status])
  @@index([dataVencimento])
  @@index([projetoId])
  @@index([serviceOrderId])
  @@index([projectPermitId])
  @@index([purchaseOrderId])
  @@map("expenses")
}

model ExpenseCategory {
  id        Int     @id @default(autoincrement())
  empresaId Int
  nome      String  @db.VarChar(100)
  descricao String? @db.Text
  cor       String  @default("#EF4444") @db.VarChar(7) // Vermelho para despesas
  icone     String? @db.VarChar(50)
  ativo     Boolean @default(true)

  // Budget (opcional)
  orcamentoMensal Decimal? @db.Decimal(10, 2)

  // Tax Compliance: Schedule C mapping
  scheduleCLine String?  @map("schedule_c_line") @db.VarChar(20)
  slug          String?  @unique @db.VarChar(50)
  dedutivel     Boolean  @default(true)

  // Metadata
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations
  empresa  Empresa   @relation(fields: [empresaId], references: [id])
  despesas Expense[]

  @@unique([empresaId, nome])
  @@map("expense_categories")
}

model ExpenseApproval {
  id        Int @id @default(autoincrement())
  expenseId Int @unique

  // Status da aprovação
  status StatusAprovacao @default(PENDENTE)

  // Aprovadores
  aprovadorId   Int // Usuário responsável por aprovar
  tipoAprovador TipoAprovador @default(GERENTE)

  // Workflow
  nivelAprovacao     Int     @default(1) // Para aprovações multi-nível
  requerProximoNivel Boolean @default(false)
  proximoAprovadorId Int?

  // Datas
  solicitadoEm DateTime  @default(now())
  revisadoEm   DateTime?

  // Justificativas
  justificativa String? @db.Text // Da solicitação
  comentario    String? @db.Text // Do aprovador

  // Metadata
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relations
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  aprovador        Usuario  @relation("ExpenseAprovador", fields: [aprovadorId], references: [id])
  proximoAprovador Usuario? @relation("ExpenseProximoAprovador", fields: [proximoAprovadorId], references: [id])

  @@index([status, solicitadoEm])
  @@index([aprovadorId])
  @@map("expense_approvals")
}

