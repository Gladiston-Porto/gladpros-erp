  motivoRevogacao String? @db.VarChar(255)

  // Timestamps
  criadoEm   DateTime  @default(now())
  expiraEm   DateTime
  usadoEm    DateTime?
  revogadoEm DateTime?

  // Tracking de uso
  ip        String? @db.VarChar(45)
  userAgent String? @db.VarChar(500)

  // Relacionamento com token pai (rotation chain)
  tokenPaiId   Int?
  tokenPai     RefreshToken?  @relation("TokenRotation", fields: [tokenPaiId], references: [id], onDelete: SetNull)
  tokensFilhos RefreshToken[] @relation("TokenRotation")

  @@index([usuarioId])
  @@index([token])
  @@index([jti])
  @@index([expiraEm])
  @@index([revogado])
  @@index([tokenPaiId])
  @@index([usuarioId, revogado, expiraEm], name: "idx_refresh_usuario_ativo")
  @@map("refresh_tokens")
}

// ==================================
// KMS - Key Management System (VUL-004)
// ==================================

model EncryptionKey {
  id Int @id @default(autoincrement())

  // Tipo de chave
  keyType EncryptionKey_tipo
  version Int

  // Chave encriptada com master key
  encryptedKey String @db.Text

  // Metadados
  fingerprint String @db.VarChar(64)
  algorithm   String @db.VarChar(50)
  keyLength   Int

  // Status
  status EncryptionKey_status @default(ACTIVE)

  // Lifecycle
  criadoEm   DateTime  @default(now())
  ativadoEm  DateTime?
  expiraEm   DateTime?
  retiradoEm DateTime?

  // Auditoria
  criadoPorUsuarioId Int?
  motivoRotacao      String? @db.VarChar(255)

  // Relações
  criadoPor   Usuario?        @relation("EncryptionKeyCriadoPor", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)
  usageAudits KeyUsageAudit[] @relation("KeyUsageAuditKey")

  @@unique([keyType, version])
  @@index([keyType, status])
  @@index([expiraEm])
  @@map("encryption_keys")
}

model KeyUsageAudit {
  id BigInt @id @default(autoincrement())

  // Referência à chave
  keyId      Int
  keyVersion Int
  keyType    String @db.VarChar(50)

  // Operação
  operacao     KeyUsageAudit_operacao
  tipoEntidade String?                @db.VarChar(50)
  entidadeId   Int?

  // Resultado
  sucesso      Boolean
  mensagemErro String? @db.VarChar(500)

  // Contexto
  usuarioId Int?
  ip        String? @db.VarChar(45)
  userAgent String? @db.VarChar(500)

  // Timestamp
  timestamp DateTime @default(now())

  // Relações
  key     EncryptionKey @relation("KeyUsageAuditKey", fields: [keyId], references: [id], onDelete: Cascade)
  usuario Usuario?      @relation("KeyUsageAuditUsuario", fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([keyId])
  @@index([timestamp])
  @@index([operacao])
  @@index([sucesso])
  @@index([keyType])
  @@map("key_usage_audit")
}

// Enums para KMS
enum EncryptionKey_tipo {
  JWT_SIGNING
  DOC_ENCRYPTION
  SESSION
  BACKUP
}

enum EncryptionKey_status {
  ACTIVE
  READ_ONLY
  RETIRED
  ARCHIVED
}

enum KeyUsageAudit_operacao {
  ENCRYPT
  DECRYPT
  SIGN
  VERIFY
  DERIVE
  ROTATE
}

