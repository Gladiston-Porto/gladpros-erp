model EmployerBurdenRate {
  id Int @id @default(autoincrement())

  classification WorkerClassification

  // Taxas como percentuais (ex: 7.65 = 7.65%)
  ficaRate        Decimal @default(7.65) @map("fica_rate") @db.Decimal(5, 2) // Social Security + Medicare (employer portion)
  futaRate        Decimal @default(0.60) @map("futa_rate") @db.Decimal(5, 2) // Federal Unemployment
  sutaRate        Decimal @default(2.70) @map("suta_rate") @db.Decimal(5, 2) // State Unemployment (varies by state)
  workersCompRate Decimal @default(5.00) @map("workers_comp_rate") @db.Decimal(5, 2) // Workers Comp (varies by trade/state)
  glInsuranceRate Decimal @default(2.00) @map("gl_insurance_rate") @db.Decimal(5, 2) // GL Insurance allocation
  otherBurdenRate Decimal @default(0.00) @map("other_burden_rate") @db.Decimal(5, 2) // Benefits, PTO, etc.

  // Vigência
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  // Config scope
  empresaId Int?    @map("empresa_id")
  notes     String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([classification])
  @@index([effectiveFrom])
  @@map("employer_burden_rates")
}

// ============================================================================
// MÓDULO: SUBCONTRACTS & LIEN WAIVERS (F2.2 + F2.3)
// ============================================================================

// ---- Enums ----

enum SubcontractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  TERMINATED
}

enum SubcontractMilestoneStatus {
  PENDING
  READY // Todos os gates pass
  APPROVED
  PAID
  CANCELLED
}

enum MilestoneGateType {
  INSPECTION_OK
  PHOTOS_UPLOADED
  CHECKLIST_COMPLETE
  LIEN_WAIVER_SIGNED
  COI_VALID
  MATERIAL_RETURNED
  CUSTOM
}

enum LienWaiverType {
  CONDITIONAL_PARTIAL
  UNCONDITIONAL_PARTIAL
  CONDITIONAL_FINAL
  UNCONDITIONAL_FINAL
}

enum BudgetAlertSeverity {
  WARNING // >80% budget
  ALERT // >100% budget
  CRITICAL // >110% budget
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ChangeOrderJobType {
  PROJECT
  SERVICE_ORDER
}

enum ChangeOrderType {
  CLIENT_REQUEST
  UNFORESEEN
  COMPANY_ERROR
  CODE_REQUIREMENT
}

enum ChangeOrderStatus {
  DRAFT
  SENT
  APPROVED
  APPLIED
  REJECTED
  VOIDED
}

enum ChangeOrderItemType {
  LABOR
  MATERIAL
  FEE
  DISCOUNT
}

// ---- Models ----

model SubcontractAgreement {
  id Int @id @default(autoincrement())

  projectId Int @map("project_id")
  workerId  Int @map("worker_id")

  scope            String  @db.Text
  contractValue    Decimal @map("contract_value") @db.Decimal(12, 2)
  retainagePercent Decimal @default(10.00) @map("retainage_percent") @db.Decimal(5, 2) // US construction 5-10%

  startDate DateTime          @map("start_date")
  endDate   DateTime?         @map("end_date")
  status    SubcontractStatus @default(DRAFT)

  notes String? @db.Text

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")

  project    Projeto                @relation(fields: [projectId], references: [id])
  worker     Worker                 @relation("WorkerSubcontracts", fields: [workerId], references: [id])
  milestones SubcontractMilestone[]

  @@index([projectId])
  @@index([workerId])
  @@index([status])
  @@map("subcontract_agreements")
}

model SubcontractMilestone {
  id          Int @id @default(autoincrement())
  agreementId Int @map("agreement_id")

  title     String  @db.VarChar(200)
  sortOrder Int     @default(0) @map("sort_order")
  percent   Decimal @db.Decimal(5, 2) // ex: 40.00 para 40%
  amount    Decimal @db.Decimal(12, 2) // valor calculado
  dueRule   String? @map("due_rule") @db.VarChar(200) // "30 days after start", etc.

  status SubcontractMilestoneStatus @default(PENDING)

  // Link com Payable quando pagamento é gerado
  payableId Int? @unique @map("payable_id")

  completedAt  DateTime? @map("completed_at")
  approvedAt   DateTime? @map("approved_at")
  approvedById Int?      @map("approved_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agreement SubcontractAgreement       @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  gates     SubcontractMilestoneGate[]

  @@index([agreementId])
  @@index([status])
  @@map("subcontract_milestones")
}

model SubcontractMilestoneGate {
  id          Int @id @default(autoincrement())
  milestoneId Int @map("milestone_id")

  gateType   MilestoneGateType @map("gate_type")
  label      String?           @db.VarChar(200)
  required   Boolean           @default(true)
  passed     Boolean           @default(false)
  passedAt   DateTime?         @map("passed_at")
  passedById Int?              @map("passed_by_id")
  notes      String?           @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  milestone SubcontractMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@map("subcontract_milestone_gates")
}

// F2.3: Lien Waivers

model LienWaiver {
  id Int @id @default(autoincrement())

  workerId  Int @map("worker_id")
  projectId Int @map("project_id")

  type        LienWaiverType
  amount      Decimal        @db.Decimal(12, 2)
  throughDate DateTime       @map("through_date") // Coberto até esta data
  signedAt    DateTime?      @map("signed_at")
  documentUrl String?        @map("document_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  worker Worker @relation("WorkerLienWaivers", fields: [workerId], references: [id])

  @@index([workerId])
  @@index([projectId])
  @@index([type])
  @@map("lien_waivers")
}

// F2.3: Budget Alerts

model BudgetAlert {
  id Int @id @default(autoincrement())

  projectId    Int                 @map("project_id")
  severity     BudgetAlertSeverity
  thresholdPct Decimal             @map("threshold_pct") @db.Decimal(5, 2) // 80, 100, 110
  custoAtual   Decimal             @map("custo_atual") @db.Decimal(12, 2)
  budgetTotal  Decimal             @map("budget_total") @db.Decimal(12, 2)
  percentUsed  Decimal             @map("percent_used") @db.Decimal(7, 2)
  message      String?             @db.VarChar(500)

  triggeredAt    DateTime  @default(now()) @map("triggered_at")
  acknowledgedBy Int?      @map("acknowledged_by")
  acknowledgedAt DateTime? @map("acknowledged_at")

  project Projeto @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([severity])
  @@index([triggeredAt])
  @@map("budget_alerts")
}

// F2.5: Commitments / Purchase Orders

model PurchaseOrder {
  id Int @id @default(autoincrement())

  empresaId      Int  @map("empresa_id")
  projectId      Int? @map("project_id")
  serviceOrderId Int? @map("service_order_id")
  vendorId       Int  @map("vendor_id")

  status         PurchaseOrderStatus @default(DRAFT)
  totalAmount    Decimal             @map("total_amount") @db.Decimal(12, 2)
  receivedAmount Decimal             @default(0) @map("received_amount") @db.Decimal(12, 2)

  approvedBy Int?      @map("approved_by")
  approvedAt DateTime? @map("approved_at")

  submittedBy Int?      @map("submitted_by")
  submittedAt DateTime? @map("submitted_at")

  notes String? @db.Text

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")

  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  project      Projeto?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  vendor       Fornecedor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  approver  Usuario? @relation("PurchaseOrderAprovador", fields: [approvedBy], references: [id], onDelete: SetNull)
  submitter Usuario? @relation("PurchaseOrderSubmetidoPor", fields: [submittedBy], references: [id], onDelete: SetNull)
  creator   Usuario? @relation("PurchaseOrderCriador", fields: [createdById], references: [id], onDelete: SetNull)

  items    PurchaseOrderItem[]
  expenses Expense[]
  compras  Compra[]

  @@index([empresaId])
  @@index([projectId])
  @@index([serviceOrderId])
  @@index([vendorId])
  @@index([status])
  @@index([approvedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id Int @id @default(autoincrement())

  poId       Int  @map("po_id")
  materialId Int? @map("material_id")

  description String  @db.VarChar(255)
  quantity    Decimal @db.Decimal(14, 3)
  unitCost    Decimal @map("unit_cost") @db.Decimal(12, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  material      Material?     @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([poId])
  @@index([materialId])
  @@map("purchase_order_items")
}

// F3.2A: Change Orders

model ChangeOrder {
  id Int @id @default(autoincrement())

  jobType        ChangeOrderJobType @map("job_type")
  projectId      Int?               @map("project_id")
  serviceOrderId Int?               @map("service_order_id")

  type        ChangeOrderType
  status      ChangeOrderStatus @default(DRAFT)
  description String            @db.Text

  priceDelta Decimal @default(0) @map("price_delta") @db.Decimal(12, 2)
  costDelta  Decimal @default(0) @map("cost_delta") @db.Decimal(12, 2)
  taxDelta   Decimal @default(0) @map("tax_delta") @db.Decimal(12, 2)

  rootCause            String? @map("root_cause") @db.VarChar(500)
  clientApprovalMethod String? @map("client_approval_method") @db.VarChar(50)
  signatureUrl         String? @map("signature_url") @db.VarChar(500)

  sentAt            DateTime? @map("sent_at")
  sentBy            Int?      @map("sent_by")
  approvedAt        DateTime? @map("approved_at")
  approvedByName    String?   @map("approved_by_name") @db.VarChar(120)
  approvedIp        String?   @map("approved_ip") @db.VarChar(64)
  approvedUserAgent String?   @map("approved_user_agent") @db.VarChar(255)
  approvedBy        Int?      @map("approved_by")
  appliedAt         DateTime? @map("applied_at")
  appliedBy         Int?      @map("applied_by")
  rejectedAt        DateTime? @map("rejected_at")
  rejectedByName    String?   @map("rejected_by_name") @db.VarChar(120)
  rejectedIp        String?   @map("rejected_ip") @db.VarChar(64)
  rejectedUserAgent String?   @map("rejected_user_agent") @db.VarChar(255)
  rejectedBy        Int?      @map("rejected_by")
  rejectedReason    String?   @map("rejected_reason") @db.VarChar(500)
  voidedAt          DateTime? @map("voided_at")
  voidedBy          Int?      @map("voided_by")
  voidedReason      String?   @map("voided_reason") @db.VarChar(500)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById Int?     @map("created_by_id")

  project      Projeto?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)

  createdByUser  Usuario? @relation("ChangeOrderCriador", fields: [createdById], references: [id], onDelete: SetNull)
  sentByUser     Usuario? @relation("ChangeOrderEnviadoPor", fields: [sentBy], references: [id], onDelete: SetNull)
  approvedByUser Usuario? @relation("ChangeOrderAprovadoPor", fields: [approvedBy], references: [id], onDelete: SetNull)
  appliedByUser  Usuario? @relation("ChangeOrderAplicadoPor", fields: [appliedBy], references: [id], onDelete: SetNull)
  rejectedByUser Usuario? @relation("ChangeOrderRejeitadoPor", fields: [rejectedBy], references: [id], onDelete: SetNull)
  voidedByUser   Usuario? @relation("ChangeOrderAnuladoPor", fields: [voidedBy], references: [id], onDelete: SetNull)

