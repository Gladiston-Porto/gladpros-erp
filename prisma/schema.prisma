// ============================================================================
// MÓDULO FINANCEIRO - INVOICE SYSTEM (Semana 0)
// ============================================================================

model Invoice {
  id                  Int            @id @default(autoincrement())
  numeroInvoice       String         @unique @db.VarChar(50)
  projetoId           Int?
  propostaId          Int?
  clienteId           Int
  dataEmissao         DateTime       @default(now())
  dataVencimento      DateTime
  dataPagamento       DateTime?
  subtotal            Decimal        @default(0) @db.Decimal(15, 2)
  descontoValor       Decimal        @default(0) @db.Decimal(15, 2)
  descontoPercentual  Decimal        @default(0) @db.Decimal(5, 2)
  // taxRateId removed
  taxRate             Decimal        @default(0.0825) @db.Decimal(5, 4)
  taxAmount           Decimal        @default(0)      @db.Decimal(15, 2)

  // Sales Tax Classification (Fase 2) — inherited from ServiceOrder or set manually
  propertyType          PropertyType?    @map("property_type")
  serviceCategory       ServiceCategory? @map("service_category")
  contractType          ContractType?    @map("contract_type")
  taxMode               TaxMode?         @default(NON_TAXABLE)  @map("tax_mode")
  taxScenario           String?          @db.VarChar(1)   @map("tax_scenario")    // A|B|C|D|E
  taxableAmount         Decimal          @default(0)      @db.Decimal(15, 2) @map("taxable_amount")
  nonTaxableAmount      Decimal          @default(0)      @db.Decimal(15, 2) @map("non_taxable_amount")
  taxExplanation        String?          @db.Text         @map("tax_explanation")
  taxAddressCity        String?          @db.VarChar(100) @map("tax_address_city")
  taxAddressState       String?          @db.VarChar(10)  @map("tax_address_state")
  taxAddressZip         String?          @db.VarChar(20)  @map("tax_address_zip")
  // Manual Override — only ADMIN/FINANCEIRO
  manualTaxOverride     Boolean          @default(false)  @map("manual_tax_override")
  manualTaxOverrideReason String?        @db.VarChar(500) @map("manual_tax_override_reason")
  taxReviewedById       Int?             @map("tax_reviewed_by_id")
  taxReviewedAt         DateTime?        @map("tax_reviewed_at")

  valorTotal          Decimal        @default(0) @db.Decimal(15, 2)
  valorPago           Decimal        @default(0) @db.Decimal(15, 2)
  saldo               Decimal        @default(0) @db.Decimal(15, 2)
  status              Invoice_status @default(DRAFT)
  notas               String?        @db.Text
  termos              String?        @db.Text
  ledgerTransactionId Int?           @unique
  criadoPor           Int
  empresaId           Int            @default(1)
  atualizadoPor       Int?
  criadoEm            DateTime       @default(now())
  atualizadoEm        DateTime       @updatedAt
  pdfStorageKey       String?        @db.VarChar(255)
  pdfFileName         String?        @db.VarChar(255)
  pdfGeneratedAt      DateTime?      @db.DateTime(3)
  pdfSizeBytes        Int?
  pdfMimeType         String?        @db.VarChar(100)
  pdfSha256           String?        @db.Char(64)

  // Relations
  projeto          Projeto?          @relation(fields: [projetoId], references: [id])
  proposta         Proposta?         @relation(fields: [propostaId], references: [id])
  cliente          Cliente           @relation(fields: [clienteId], references: [id])
  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  // taxRateRel removed
  criador          Usuario           @relation("InvoiceCriador", fields: [criadoPor], references: [id])
  atualizador      Usuario?          @relation("InvoiceAtualizador", fields: [atualizadoPor], references: [id])
  taxReviewedBy    Usuario?          @relation("InvoiceTaxReviewer", fields: [taxReviewedById], references: [id])
  itens       InvoiceItem[]
  pagamentos  InvoicePayment[]
  lembretes   InvoiceReminder[]

  // ServiceOrder Link (V3.1)
  ServiceOrder ServiceOrder?

  @@index([numeroInvoice])
  @@index([clienteId])
  @@index([projetoId])
  @@index([propostaId])
  @@index([status])
  @@index([dataVencimento])
  @@index([criadoEm])
  @@index([empresaId, status])
  @@index([clienteId, status])
  @@index([taxMode])
  @@index([taxReviewedById])
}

model InvoiceItem {
  id              Int              @id @default(autoincrement())
  invoiceId       Int
  tipo            InvoiceItem_tipo @default(SERVICE)
  descricao       String           @db.VarChar(500)
  quantidade      Decimal          @default(1) @db.Decimal(15, 4)
  unidade         String           @db.VarChar(50)
  precoUnitario   Decimal          @db.Decimal(15, 2)
  desconto        Decimal          @default(0) @db.Decimal(15, 2)
  subtotal        Decimal          @db.Decimal(15, 2)
  taxavel         Boolean          @default(true)
  propostaEtapaId Int?
  materialId      Int?
  ordem           Int              @default(0)

  // Relations
  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  propostaEtapa PropostaEtapa? @relation(fields: [propostaEtapaId], references: [id])
  material      Material?      @relation(fields: [materialId], references: [id])

  @@index([invoiceId])
  @@index([propostaEtapaId])
  @@index([materialId])
}

model InvoicePayment {
  id                   Int                   @id @default(autoincrement())
  invoiceId            Int
  valor                Decimal               @db.Decimal(15, 2)
  dataPagamento        DateTime
  metodoPagamento      InvoicePayment_metodo @default(BANK_TRANSFER)
  bankAccountId        Int?
  referencia           String?               @db.VarChar(100)
  notas                String?               @db.Text
  ledgerTransactionId  Int?                  @unique
  gatewayId            String?               @db.VarChar(100)
  gatewayTransactionId String?               @db.VarChar(255)
  criadoPor            Int
  criadoEm             DateTime              @default(now())

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  criador Usuario @relation(fields: [criadoPor], references: [id])

  @@index([invoiceId])
  @@index([dataPagamento])
  @@index([gatewayTransactionId])
}

model InvoiceReminder {
  id                 Int                    @id @default(autoincrement())
  invoiceId          Int
  tipo               InvoiceReminder_tipo   @default(REMINDER)
  diasAposVencimento Int                    @default(0)
  dataEnvio          DateTime?
  metodo             InvoiceReminder_metodo @default(EMAIL)
  destinatario       String                 @db.VarChar(255)
  assunto            String?                @db.VarChar(255)
  mensagem           String?                @db.Text
  status             InvoiceReminder_status @default(SENT)
  erro               String?                @db.Text
  criadoEm           DateTime               @default(now())

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([tipo])
  @@index([status])
  @@index([dataEnvio])
}

