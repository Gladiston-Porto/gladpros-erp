  projetoTarefas         ProjetoTarefa[]         @relation("ChangeOrderProjetoTarefas")
  serviceOrderMaterials  ServiceOrderMaterial[]  @relation("ChangeOrderServiceOrderMaterials")
  serviceOrderScopeItems ServiceOrderScopeItem[] @relation("ChangeOrderServiceOrderScopeItems")

  @@index([jobType])
  @@index([projectId])
  @@index([serviceOrderId])
  @@index([status])
  @@index([type])
  @@index([appliedAt])
  @@index([appliedBy])
  @@index([createdAt])
  @@map("change_orders")
