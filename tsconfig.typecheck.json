{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "forceConsistentCasingInFileNames": false
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "src/app/api/grupos/**/*.ts",
    "src/components/propostas/**/*.tsx",
    "src/lib/auth/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "docs",
    "_duplicados_para_revisao",
    "packages",
    ".next",
    "dist",
    "build",
    "coverage",
    "playwright-report",
    "test-results",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "scripts",
    "**/__tests__",
    "prisma/seed*.ts",
    "src/lib/seed*.ts",
    "src/lib/seed-invoice.ts",
    "src/domains/projects/services",
    "src/modules/propostas",
    "src/services/estimation.service.ts",
    "src/services/tax-resolver.service.ts",
    "src/middleware/auth-middleware.ts"
  ]
}
