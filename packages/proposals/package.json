{
  "name": "@gladpros/proposals",
  "version": "1.0.0",
  "description": "Proposal management module for GladPros applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "proposals",
    "business",
    "management",
    "gladpros"
  ],
  "author": "GladPros Team",
  "license": "MIT",
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@gladpros/auth": "*",
    "@gladpros/ui": "*",
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Gladiston-Porto/gladpros-proposals.git"
  },
  "bugs": {
    "url": "https://github.com/Gladiston-Porto/gladpros-proposals/issues"
  },
  "homepage": "https://github.com/Gladiston-Porto/gladpros-proposals#readme"
}
