{
  "name": "@gladpros/financeiro",
  "version": "1.0.0",
  "description": "GladPros Financeiro Module - Financial Management System",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./app": {
      "import": "./src/app/index.ts",
      "require": "./src/app/index.ts"
    },
    "./api": {
      "import": "./src/api/index.ts",
      "require": "./src/api/index.ts"
    },
    "./components": {
      "import": "./src/components/index.ts",
      "require": "./src/components/index.ts"
    },
    "./lib": {
      "import": "./src/lib/index.ts",
      "require": "./src/lib/index.ts"
    },
    "./gateways": {
      "import": "./src/gateways/index.ts",
      "require": "./src/gateways/index.ts"
    },
    "./types": {
      "import": "./src/types/index.ts",
      "require": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "gladpros",
    "financeiro",
    "financial",
    "module"
  ],
  "author": "GladPros Team",
  "license": "MIT",
  "dependencies": {
    "next": "^15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.1.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
