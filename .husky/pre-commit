# GladPros ERP — Pre-commit Quality Gate
# Detecta anti-patterns e regressões ANTES do commit.
#
# Para bypass de EMERGÊNCIA (proibido em código de produção): git commit --no-verify
# Ver: docs/architecture/06-production-readiness.md
#
# CI roda os mesmos checks → bypass local não escapa.

set -e

echo ""
echo "🔍 GladPros Quality Gate — Pre-commit"
echo "─────────────────────────────────────────"

# Camada 0: validação do registro de bugs conhecidos
echo "▶ Validando relatorios/known-bugs.json..."
node scripts/validate-known-bugs.mjs

# Camada 1: padrões regex (script atual)
echo ""
echo "▶ Health check de anti-patterns (regex)..."
node scripts/check-module-health.mjs --staged

# Camada 2: Semgrep (regras semânticas / AST)
# Só roda se semgrep estiver instalado — não bloqueia onboarding de novos devs.
if command -v semgrep >/dev/null 2>&1; then
  echo ""
  echo "▶ Semgrep (regras semânticas GladPros)..."
  STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -v node_modules || true)
  RULE_COUNT=$(find .semgrep/gladpros -name '*.yml' 2>/dev/null | wc -l | tr -d ' ')
  if [ "$RULE_COUNT" = "0" ]; then
    echo "❌ Semgrep: nenhuma regra encontrada em .semgrep/gladpros — configuração quebrada."
    exit 1
  fi
  if [ -n "$STAGED_TS" ]; then
    FILE_COUNT=$(echo "$STAGED_TS" | wc -l | tr -d ' ')
    echo "  Regras: $RULE_COUNT | Arquivos staged: $FILE_COUNT"
    echo "$STAGED_TS" | xargs semgrep --config=.semgrep/gladpros --metrics=off --error --quiet || {
      echo "❌ Semgrep encontrou violações — corrija antes do commit."
      exit 1
    }
    echo "  ✅ Semgrep limpo ($RULE_COUNT regras, $FILE_COUNT arquivos)."
  else
    echo "  (nenhum .ts/.tsx staged — pulando, $RULE_COUNT regras disponíveis)"
  fi
else
  echo ""
  echo "⚠️  semgrep NÃO instalado localmente — pulando Camada 2."
  echo "   Instale: brew install semgrep | pip install semgrep"
  echo "   CI ainda roda essa checagem — bypass local não escapa."
fi

# lint-staged (eslint + prettier nos arquivos staged)
echo ""
echo "▶ lint-staged (ESLint + Prettier)..."
npx lint-staged

echo ""
echo "✅ Quality Gate passou — commit permitido."
echo ""
